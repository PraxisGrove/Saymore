import "../fonts/InterVariable.ttf";
import { ScrollView } from "std-widgets.slint";

import { OverlayColors } from "overlay-color-system.slint";

export component ResultOverlay inherits Window {
    title: "Saymore Result";
    default-font-family: "Inter";
    preferred-width: 400px;
    preferred-height: 232px;
    min-width: 400px;
    min-height: 232px;
    max-width: 400px;
    max-height: 232px;
    no-frame: true;
    always-on-top: true;
    background: transparent;

    in property <string> transcript: "";
    callback copy-result();
    callback close-result();

    Rectangle {
        x: 7px;
        y: 7px;
        width: 386px;
        height: 216px;
        border-radius: 18px;
        background: OverlayColors.surface;
        border-width: 1px;
        border-color: OverlayColors.border;

        Rectangle {
            x: 13px; y: 15px; width: 24px; height: 24px; border-radius: 12px; background: OverlayColors.info-soft;
            Text { text: "i"; color: OverlayColors.info; font-size: 14px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
        }
        Text { x: 45px; y: 15px; width: 270px; height: 24px; text: @tr("result.copy-last-transcript.title" => "Copy the latest transcript"); color: OverlayColors.ink; font-size: 15px; font-weight: 700; vertical-alignment: center; }

        Rectangle {
            x: 350px; y: 13px; width: 24px; height: 24px; border-radius: 8px;
            background: close-area.has-hover ? OverlayColors.surface-subtle : transparent;
            accessible-role: button; accessible-label: @tr("result.close-panel.accessible-label" => "Close transcript panel");
            accessible-action-default => { root.close-result(); }
            Text { text: "×"; color: OverlayColors.text-muted; font-size: 17px; horizontal-alignment: center; vertical-alignment: center; }
            close-area := TouchArea { mouse-cursor: pointer; clicked => { root.close-result(); } }
        }

        Rectangle {
            x: 13px; y: 51px; width: 360px; height: 98px; border-radius: 10px; background: OverlayColors.surface-subtle;
            transcript-scroll := ScrollView {
                x: 14px;
                y: 8px;
                width: 332px;
                height: 82px;
                viewport-width: self.width;
                viewport-height: max(self.height, transcript-copy.preferred-height);
                vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

                transcript-copy := Text {
                    width: transcript-scroll.viewport-width - 8px;
                    height: self.preferred-height;
                    text: @tr("result.transcript.quoted" => "“{}”", root.transcript);
                    color: OverlayColors.text;
                    font-size: 12px;
                    wrap: word-wrap;
                }
            }
        }

        Text { x: 15px; y: 172px; text: @tr("result.content-preserved" => "Your text has been preserved"); color: OverlayColors.text-muted; font-size: 10px; vertical-alignment: center; }

        Rectangle {
            x: 217px; y: 169px; width: 64px; height: 34px; border-radius: 10px;
            background: dismiss-area.has-hover ? OverlayColors.surface-subtle-hover : OverlayColors.surface-subtle;
            accessible-role: button; accessible-label: @tr("common.close" => "Close");
            accessible-action-default => { root.close-result(); }
            Text { text: @tr("common.close" => "Close"); color: OverlayColors.text; font-size: 11px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
            dismiss-area := TouchArea { mouse-cursor: pointer; clicked => { root.close-result(); } }
        }
        Rectangle {
            x: 291px; y: 169px; width: 82px; height: 34px; border-radius: 10px;
            background: copy-area.pressed ? OverlayColors.accent-strong : copy-area.has-hover ? OverlayColors.accent-strong : OverlayColors.accent;
            accessible-role: button; accessible-label: @tr("result.copy-text" => "Copy text");
            accessible-action-default => { root.copy-result(); }
            Text { text: @tr("result.copy-text" => "Copy text"); color: OverlayColors.on-accent; font-size: 11px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
            copy-area := TouchArea { mouse-cursor: pointer; clicked => { root.copy-result(); } }
        }
    }
}
