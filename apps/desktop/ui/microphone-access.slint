import "../fonts/InterVariable.ttf";
import { OverlayColors } from "overlay-color-system.slint";

export component MicrophoneIntroOverlay inherits Window {
    title: "Saymore Microphone";
    default-font-family: "Inter";
    preferred-width: 400px;
    preferred-height: 176px;
    min-width: 400px;
    min-height: 176px;
    max-width: 400px;
    max-height: 176px;
    no-frame: true;
    always-on-top: true;
    background: transparent;
    callback dismiss();
    callback continue-requested();

    Rectangle {
        x: 7px; y: 7px; width: 386px; height: 160px; border-radius: 18px;
        background: OverlayColors.surface; border-width: 1px; border-color: OverlayColors.border;

        Rectangle { x: 13px; y: 15px; width: 24px; height: 24px; border-radius: 12px; background: OverlayColors.info-soft; Rectangle { x: 7px; y: 7px; width: 10px; height: 10px; border-radius: 5px; background: OverlayColors.info; } }
        Text { x: 45px; y: 15px; width: 300px; height: 24px; text: @tr("microphone.intro.title" => "Get started with voice input"); color: OverlayColors.ink; font-size: 15px; font-weight: 700; vertical-alignment: center; }

        Rectangle {
            x: 13px; y: 51px; width: 360px; height: 50px; border-radius: 10px; background: OverlayColors.surface-subtle;
            Text { x: 14px; y: 7px; text: @tr("microphone.intro.permission-reason" => "Saymore needs microphone access for voice recognition."); color: OverlayColors.text; font-size: 11px; }
            Text { x: 14px; y: 26px; text: @tr("microphone.intro.privacy" => "The microphone is used only when you start recording."); color: OverlayColors.text-muted; font-size: 10px; }
        }

        Rectangle {
            x: 217px; y: 113px; width: 64px; height: 34px; border-radius: 10px;
            background: dismiss-area.has-hover ? OverlayColors.surface-subtle-hover : OverlayColors.surface-subtle;
            accessible-role: button; accessible-label: @tr("microphone.intro.not-now-accessible" => "Not now");
            accessible-action-default => { root.dismiss(); }
            Text { text: @tr("common.not-now" => "Not now"); color: OverlayColors.text; font-size: 11px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
            dismiss-area := TouchArea { mouse-cursor: pointer; clicked => { root.dismiss(); } }
        }
        Rectangle {
            x: 291px; y: 113px; width: 82px; height: 34px; border-radius: 10px;
            background: continue-area.pressed ? OverlayColors.accent-strong : continue-area.has-hover ? OverlayColors.accent-strong : OverlayColors.accent;
            accessible-role: button; accessible-label: @tr("microphone.intro.continue-accessible" => "Continue to microphone access");
            accessible-action-default => { root.continue-requested(); }
            Text { text: @tr("common.continue" => "Continue"); color: OverlayColors.on-accent; font-size: 11px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
            continue-area := TouchArea { mouse-cursor: pointer; clicked => { root.continue-requested(); } }
        }
    }
}

export component MicrophonePermissionOverlay inherits Window {
    title: "Saymore Microphone Permission";
    default-font-family: "Inter";
    preferred-width: 400px;
    preferred-height: 96px;
    min-width: 400px;
    min-height: 96px;
    max-width: 400px;
    max-height: 96px;
    no-frame: true;
    always-on-top: true;
    background: transparent;
    callback dismiss();
    callback open-settings();

    Rectangle {
        x: 7px; y: 6px; width: 386px; height: 82px; border-radius: 16px;
        background: OverlayColors.surface; border-width: 1px; border-color: OverlayColors.border;

        Rectangle { x: 12px; y: 26px; width: 30px; height: 30px; border-radius: 15px; background: OverlayColors.info-soft; Rectangle { x: 10px; y: 10px; width: 10px; height: 10px; border-radius: 5px; background: OverlayColors.info; } }
        Text { x: 52px; y: 18px; text: @tr("microphone.permission.title" => "Microphone access required"); color: OverlayColors.ink; font-size: 13px; font-weight: 700; }
        Text { x: 52px; y: 41px; width: 205px; text: @tr("microphone.permission.detail" => "Allow Saymore to use the microphone to begin"); color: OverlayColors.text-muted; font-size: 10px; overflow: elide; }

        Rectangle {
            x: 267px; y: 24px; width: 100px; height: 34px; border-radius: 10px; background: settings-area.has-hover ? OverlayColors.text : OverlayColors.ink;
            accessible-role: button; accessible-label: @tr("common.open-system-settings" => "Open System Settings");
            accessible-action-default => { root.open-settings(); }
            Text { text: @tr("common.open-system-settings" => "Open System Settings"); color: OverlayColors.on-accent; font-size: 10px; font-weight: 650; horizontal-alignment: center; vertical-alignment: center; }
            settings-area := TouchArea { mouse-cursor: pointer; clicked => { root.open-settings(); } }
        }
        TouchArea { width: 258px; height: parent.height; clicked => { root.dismiss(); } }
    }
}

export component AccessibilityPermissionOverlay inherits Window {
    title: "Saymore Accessibility Permission";
    default-font-family: "Inter";
    preferred-width: 420px;
    preferred-height: 104px;
    min-width: 420px;
    min-height: 104px;
    max-width: 420px;
    max-height: 104px;
    no-frame: true;
    always-on-top: true;
    background: transparent;
    callback dismiss();
    callback open-settings();

    Rectangle {
        x: 7px; y: 6px; width: 406px; height: 90px; border-radius: 16px;
        background: OverlayColors.surface; border-width: 1px; border-color: OverlayColors.border;

        Rectangle {
            x: 12px; y: 30px; width: 30px; height: 30px; border-radius: 9px; background: OverlayColors.surface-subtle;
            Image { x: 7px; y: 7px; width: 16px; height: 16px; source: @image-url("../icons/lucide/shield.svg"); colorize: OverlayColors.text; }
        }
        Text { x: 52px; y: 18px; width: 196px; text: @tr("accessibility.permission.title" => "Accessibility permission required"); color: OverlayColors.ink; font-size: 13px; font-weight: 700; overflow: elide; }
        Text { x: 52px; y: 41px; width: 196px; height: 32px; text: @tr("accessibility.permission.detail" => "Allow Saymore to detect the shortcut and insert text."); color: OverlayColors.text-muted; font-size: 10px; wrap: word-wrap; }

        Rectangle {
            x: 254px; y: 28px; width: 112px; height: 34px; border-radius: 10px; background: settings-area.has-hover ? OverlayColors.text : OverlayColors.ink;
            accessible-role: button; accessible-label: @tr("common.open-system-settings" => "Open System Settings");
            accessible-action-default => { root.open-settings(); }
            Text { x: 8px; width: parent.width - 16px; text: @tr("common.open-system-settings" => "Open System Settings"); color: OverlayColors.on-accent; font-size: 10px; font-weight: 650; horizontal-alignment: center; vertical-alignment: center; overflow: elide; }
            settings-area := TouchArea { mouse-cursor: pointer; clicked => { root.open-settings(); } }
        }
        Rectangle {
            x: 374px; y: 33px; width: 24px; height: 24px; border-radius: 6px;
            background: close-area.has-hover ? OverlayColors.surface-subtle : transparent;
            accessible-role: button; accessible-label: @tr("common.close" => "Close");
            accessible-action-default => { root.dismiss(); }
            Image { x: 6px; y: 6px; width: 12px; height: 12px; source: @image-url("../icons/lucide/x.svg"); colorize: OverlayColors.text-muted; }
            close-area := TouchArea { mouse-cursor: pointer; clicked => { root.dismiss(); } }
        }
    }
}

export component AsrConfigurationOverlay inherits Window {
    title: "Saymore Voice Recognition Setup";
    default-font-family: "PingFang SC";
    preferred-width: 392px;
    preferred-height: 150px;
    min-width: 392px;
    min-height: 150px;
    max-width: 392px;
    max-height: 150px;
    no-frame: true;
    always-on-top: true;
    background: transparent;
    callback dismiss();
    callback open-configuration();

    Rectangle {
        x: 6px; y: 6px; width: 380px; height: 138px; border-radius: 14px;
        background: OverlayColors.surface; border-width: 1px; border-color: OverlayColors.border;
        drop-shadow-blur: 20px; drop-shadow-offset-y: 6px; drop-shadow-color: OverlayColors.shadow-strong;

        Rectangle {
            x: 18px; y: 18px; width: 38px; height: 38px; border-radius: 9px; background: OverlayColors.surface-subtle;
            Image { x: 6px; y: 6px; width: 26px; height: 26px; source: @image-url("../icons/saymore-mark-3d-136.png"); image-fit: contain; }
        }
        Text { x: 70px; y: 17px; width: 286px; height: 24px; text: @tr("asr.configuration-required.title" => "Set up voice recognition first"); color: OverlayColors.ink; font-size: 14px; font-weight: 700; vertical-alignment: center; }
        Text {
            x: 70px; y: 44px; width: 286px; height: 38px;
            text: @tr("asr.configuration-required.detail" => "Saymore needs a voice recognition service to turn your recording into text. Configure one, then press the shortcut again.");
            color: OverlayColors.text-muted; font-size: 10px; wrap: word-wrap; vertical-alignment: top;
        }

        Rectangle {
            x: 198px; y: 94px; width: 74px; height: 30px; border-radius: 7px;
            background: dismiss-area.has-hover ? OverlayColors.surface-subtle-hover : transparent;
            accessible-role: button; accessible-label: @tr("asr.configuration-required.not-now-accessible" => "Do not configure voice recognition now");
            accessible-action-default => { root.dismiss(); }
            Text { text: @tr("common.not-now" => "Not now"); color: OverlayColors.text-muted-strong; font-size: 10px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
            dismiss-area := TouchArea { mouse-cursor: pointer; clicked => { root.dismiss(); } }
        }
        Rectangle {
            x: 282px; y: 94px; width: 80px; height: 30px; border-radius: 7px;
            background: configure-area.pressed ? OverlayColors.accent-strong : configure-area.has-hover ? OverlayColors.accent-strong : OverlayColors.accent;
            accessible-role: button; accessible-label: @tr("asr.configuration-required.open-accessible" => "Open voice recognition settings");
            accessible-action-default => { root.open-configuration(); }
            Text { text: @tr("asr.configuration-required.open" => "Set up now"); color: OverlayColors.on-accent; font-size: 10px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
            configure-area := TouchArea { mouse-cursor: pointer; clicked => { root.open-configuration(); } }
        }
    }
}
