import "../fonts/InterVariable.ttf";

export component MicrophoneIntroOverlay inherits Window {
    title: "Saymore Microphone";
    default-font-family: "Inter";
    preferred-width: 400px;
    preferred-height: 176px;
    min-width: 400px;
    min-height: 176px;
    max-width: 400px;
    max-height: 176px;
    no-frame: true;
    always-on-top: true;
    background: transparent;
    callback dismiss();
    callback continue-requested();

    Rectangle {
        x: 7px; y: 7px; width: 386px; height: 160px; border-radius: 18px;
        background: #ffffff; border-width: 1px; border-color: #e6e5e0;

        Rectangle { x: 13px; y: 15px; width: 24px; height: 24px; border-radius: 12px; background: #cbe1fb; Rectangle { x: 7px; y: 7px; width: 10px; height: 10px; border-radius: 5px; background: #256bc1; } }
        Text { x: 45px; y: 15px; width: 300px; height: 24px; text: @tr("microphone.intro.title" => "Get started with voice input"); color: #141413; font-size: 15px; font-weight: 700; vertical-alignment: center; }

        Rectangle {
            x: 13px; y: 51px; width: 360px; height: 50px; border-radius: 10px; background: #f4f4f1;
            Text { x: 14px; y: 7px; text: @tr("microphone.intro.permission-reason" => "Saymore needs microphone access for voice recognition."); color: #373734; font-size: 11px; }
            Text { x: 14px; y: 26px; text: @tr("microphone.intro.privacy" => "The microphone is used only when you start recording."); color: #7b7974; font-size: 10px; }
        }

        Rectangle {
            x: 217px; y: 113px; width: 64px; height: 34px; border-radius: 10px;
            background: dismiss-area.has-hover ? #efeeeb : #f4f4f1;
            accessible-role: button; accessible-label: @tr("microphone.intro.not-now-accessible" => "Not now");
            accessible-action-default => { root.dismiss(); }
            Text { text: @tr("common.not-now" => "Not now"); color: #373734; font-size: 11px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
            dismiss-area := TouchArea { mouse-cursor: pointer; clicked => { root.dismiss(); } }
        }
        Rectangle {
            x: 291px; y: 113px; width: 82px; height: 34px; border-radius: 10px;
            background: continue-area.pressed ? #c6613f : continue-area.has-hover ? #c6613f : #d97757;
            accessible-role: button; accessible-label: @tr("microphone.intro.continue-accessible" => "Continue to microphone access");
            accessible-action-default => { root.continue-requested(); }
            Text { text: @tr("common.continue" => "Continue"); color: #ffffff; font-size: 11px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
            continue-area := TouchArea { mouse-cursor: pointer; clicked => { root.continue-requested(); } }
        }
    }
}

export component MicrophonePermissionOverlay inherits Window {
    title: "Saymore Microphone Permission";
    default-font-family: "Inter";
    preferred-width: 400px;
    preferred-height: 96px;
    min-width: 400px;
    min-height: 96px;
    max-width: 400px;
    max-height: 96px;
    no-frame: true;
    always-on-top: true;
    background: transparent;
    callback dismiss();
    callback open-settings();

    Rectangle {
        x: 7px; y: 6px; width: 386px; height: 82px; border-radius: 16px;
        background: #ffffff; border-width: 1px; border-color: #e6e5e0;

        Rectangle { x: 12px; y: 26px; width: 30px; height: 30px; border-radius: 15px; background: #cbe1fb; Rectangle { x: 10px; y: 10px; width: 10px; height: 10px; border-radius: 5px; background: #256bc1; } }
        Text { x: 52px; y: 18px; text: @tr("microphone.permission.title" => "Microphone access required"); color: #141413; font-size: 13px; font-weight: 700; }
        Text { x: 52px; y: 41px; width: 205px; text: @tr("microphone.permission.detail" => "Allow Saymore to use the microphone to begin"); color: #7b7974; font-size: 10px; overflow: elide; }

        Rectangle {
            x: 267px; y: 24px; width: 100px; height: 34px; border-radius: 10px; background: settings-area.has-hover ? #373734 : #141413;
            accessible-role: button; accessible-label: @tr("common.open-system-settings" => "Open System Settings");
            accessible-action-default => { root.open-settings(); }
            Text { text: @tr("common.open-system-settings" => "Open System Settings"); color: #ffffff; font-size: 10px; font-weight: 650; horizontal-alignment: center; vertical-alignment: center; }
            settings-area := TouchArea { mouse-cursor: pointer; clicked => { root.open-settings(); } }
        }
        TouchArea { width: 258px; height: parent.height; clicked => { root.dismiss(); } }
    }
}
