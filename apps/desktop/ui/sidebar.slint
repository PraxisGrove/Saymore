import { AppPage, NavItem } from "components.slint";
import { AppColors } from "color-system.slint";
import { UiTuning } from "ui-tuning.slint";

export component AppSidebar inherits Rectangle {
    in-out property <AppPage> current-page: AppPage.home;
    in property <bool> development-environment: false;
    width: UiTuning.sidebar-width * 1px;
    background: AppColors.sidebar;
    border-radius: UiTuning.sidebar-radius * 1px;

    Image {
        x: 26px;
        y: 48px;
        width: UiTuning.brand-logo-size * 1px;
        height: 35px;
        source: @image-url("../icons/saymore-mark-3d-136.png");
        image-fit: contain;
        image-rendering: smooth;
    }

    Text {
        x: 66px;
        y: 48px;
        text: "Saymore";
        color: AppColors.ink;
        font-size: UiTuning.brand-font-size * 1px;
        font-weight: 700;
    }

    if root.development-environment: Rectangle {
        x: 161px;
        y: 56px;
        width: 31px;
        height: 18px;
        border-radius: 5px;
        background: AppColors.warning-soft;
        Text { text: "DEV"; color: AppColors.warning; font-size: 9px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
    }

    NavItem { x: 26px; y: 109px; width: 146px; label: "首页"; icon: @image-url("../icons/lucide/house.svg"); selected: root.current-page == AppPage.home; activated => { root.current-page = AppPage.home; } }
    NavItem { x: 26px; y: 151px; width: 146px; label: "模型"; icon: @image-url("../icons/lucide/sparkles.svg"); selected: root.current-page == AppPage.models; activated => { root.current-page = AppPage.models; } }
    NavItem { x: 26px; y: 193px; width: 146px; label: "历史"; icon: @image-url("../icons/lucide/history.svg"); selected: root.current-page == AppPage.history; activated => { root.current-page = AppPage.history; } }
    NavItem { x: 26px; y: 235px; width: 146px; label: "词典"; icon: @image-url("../icons/lucide/book-open.svg"); selected: root.current-page == AppPage.dictionary; activated => { root.current-page = AppPage.dictionary; } }
    NavItem { x: 26px; y: 277px; width: 146px; label: "设置"; icon: @image-url("../icons/lucide/settings.svg"); selected: root.current-page == AppPage.settings; activated => { root.current-page = AppPage.settings; } }

    Rectangle {
        x: 9px;
        y: parent.height - 157px;
        width: parent.width - 20px;
        height: 118px;
        border-radius: 14px;
        background: AppColors.surface;

        Text { x: 12px; y: 11px; text: "本地存储"; color: AppColors.text-muted; font-size: 11px; font-weight: 600; }
        Text { x: 12px; y: 35px; text: "0 MB"; color: AppColors.ink; font-size: 15px; font-weight: 700; }
        Text { x: 57px; y: 40px; text: "/ 2 GB"; color: AppColors.text-muted; font-size: 10px; }
        Rectangle { x: 12px; y: 67px; width: parent.width - 24px; height: 4px; border-radius: 2px; background: AppColors.progress-track; Rectangle { width: 4px; height: 4px; border-radius: 2px; background: AppColors.brand; } }
        Rectangle {
            x: 12px;
            y: 79px;
            width: parent.width - 24px;
            height: 28px;
            border-radius: 7px;
            background: AppColors.surface-subtle;
            Text { text: "管理空间"; color: AppColors.text; font-size: 10px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
        }
    }

    Text {
        x: 0px;
        y: parent.height - 22px;
        width: parent.width;
        text: "本地优先 · 隐私保护";
        color: AppColors.text-muted;
        font-size: 9px;
        horizontal-alignment: center;
    }
}
