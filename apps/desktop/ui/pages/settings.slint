import { AppButton, AppCheckBox, AppSelect, NavItem, SettingsSection, StatusPill } from "../components.slint";
import { AppColors } from "../color-system.slint";

component SettingsRow inherits Rectangle {
    in property <string> title;
    in property <string> detail;
    height: 58px;
    background: transparent;

    HorizontalLayout {
        padding-left: 2px;
        padding-right: 2px;
        alignment: space-between;
        cross-axis-alignment: center;
        Text { text: root.title; color: AppColors.text; font-size: 13px; font-weight: 550; }
        Text { text: root.detail; color: AppColors.text-muted; font-size: 12px; }
    }

    Rectangle { y: parent.height - 1px; height: 1px; background: AppColors.border; }
}

component SettingSwitch inherits Rectangle {
    in-out property <bool> checked;
    width: 42px;
    height: 24px;
    border-radius: 12px;
    background: root.checked ? AppColors.success : AppColors.border;
    accessible-role: checkbox;
    accessible-label: root.checked ? "已开启" : "已关闭";
    accessible-checked: root.checked;
    accessible-action-default => { root.checked = !root.checked; }

    Rectangle {
        width: 18px;
        height: 18px;
        x: root.checked ? parent.width - self.width - 3px : 3px;
        y: 3px;
        border-radius: 9px;
        background: AppColors.surface;
        drop-shadow-blur: 4px;
        drop-shadow-offset-y: 1px;
        drop-shadow-color: #17130e2b;
    }

    TouchArea { clicked => { root.checked = !root.checked; } }
}

component AudioToggleRow inherits Rectangle {
    in property <string> title;
    in property <string> detail;
    in-out property <bool> checked;
    height: 76px;
    background: transparent;

    HorizontalLayout {
        padding-left: 2px;
        padding-right: 2px;
        spacing: 18px;
        cross-axis-alignment: center;

        VerticalLayout {
            spacing: 5px;
            Text { text: root.title; color: AppColors.ink; font-size: 14px; font-weight: 650; }
            Text { text: root.detail; color: AppColors.text-muted; font-size: 12px; }
        }
        Rectangle { horizontal-stretch: 1; background: transparent; }
        SettingSwitch { checked <=> root.checked; }
    }

    Rectangle { y: parent.height - 1px; height: 1px; background: AppColors.border; }
}

component PermissionRow inherits Rectangle {
    in property <string> title;
    in property <string> status;
    in property <bool> granted;
    in property <string> action-label;
    in property <bool> action-visible;
    callback action();
    height: 72px;
    border-width: 0px;
    border-radius: 8px;
    background: AppColors.surface;

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 14px;
        spacing: 12px;
        cross-axis-alignment: center;
        Text { text: root.title; color: AppColors.text; font-size: 13px; font-weight: 650; }
        Rectangle { horizontal-stretch: 1; background: transparent; }
        StatusPill { label: root.status; granted: root.granted; }
        AppButton { visible: root.action-visible; text: root.action-label; clicked => { root.action(); } }
    }
}

export component SettingsPage inherits Rectangle {
    in property <bool> authorized;
    in property <string> authorization-status;
    in property <bool> microphone-authorized;
    in property <string> microphone-status;
    in-out property <bool> history-enabled: true;
    in-out property <string> history-retention: "7 天";
    in-out property <bool> interaction-sounds-enabled: true;
    in-out property <bool> mute-other-audio-enabled: true;
    callback back-to-app();
    callback request-authorization();
    callback request-microphone-authorization();
    callback set-history-enabled(bool);
    callback set-history-retention(string);
    in-out property <SettingsSection> current-section: SettingsSection.general;
    background: AppColors.surface-muted;

    HorizontalLayout {
        padding: 10px;
        spacing: 12px;

        Rectangle {
            width: 220px;
            border-width: 0px;
            border-radius: 8px;
            background: AppColors.surface-warm;

            VerticalLayout {
                padding-left: 14px;
                padding-right: 14px;
                padding-top: 46px;
                padding-bottom: 18px;
                spacing: 5px;

                Rectangle {
                    height: 40px;
                    border-radius: 6px;
                    background: back-touch.has-hover ? AppColors.surface-muted : transparent;
                    accessible-role: button;
                    accessible-label: "返回首页";
                    accessible-action-default => { root.back-to-app(); }

                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        spacing: 9px;
                        cross-axis-alignment: center;
                        Text { text: "‹"; color: AppColors.text-muted; font-size: 22px; font-weight: 450; vertical-alignment: center; }
                        Text { text: "返回首页"; color: AppColors.text; font-size: 13px; font-weight: 550; vertical-alignment: center; }
                    }
                    back-touch := TouchArea { clicked => { root.back-to-app(); } }
                }

                Rectangle { height: 18px; background: transparent; }
                Text { height: 30px; text: "设置"; color: AppColors.ink; font-size: 20px; font-weight: 700; vertical-alignment: center; }
                Rectangle { height: 8px; background: transparent; }
                NavItem { icon: @image-url("../../icons/lucide/settings.svg"); label: "通用"; selected: root.current-section == SettingsSection.general; activated => { root.current-section = SettingsSection.general; } }
                NavItem { icon: @image-url("../../icons/lucide/settings.svg"); label: "快捷键与音频"; selected: root.current-section == SettingsSection.shortcuts-audio; activated => { root.current-section = SettingsSection.shortcuts-audio; } }
                NavItem { icon: @image-url("../../icons/lucide/check.svg"); label: "投递与权限"; selected: root.current-section == SettingsSection.delivery-permissions; activated => { root.current-section = SettingsSection.delivery-permissions; } }
                NavItem { icon: @image-url("../../icons/lucide/history.svg"); label: "隐私与历史"; selected: root.current-section == SettingsSection.privacy-history; activated => { root.current-section = SettingsSection.privacy-history; } }
                NavItem { icon: @image-url("../../icons/lucide/folder-open.svg"); label: "关于与更新"; selected: root.current-section == SettingsSection.about-updates; activated => { root.current-section = SettingsSection.about-updates; } }
                Rectangle { vertical-stretch: 1; background: transparent; }
                Text { height: 20px; text: "Saymore  v0.1.0"; color: AppColors.text-muted; font-size: 10px; horizontal-alignment: center; }
            }
        }

        Rectangle {
            border-width: 0px;
            border-radius: 8px;
            background: AppColors.canvas;

            VerticalLayout {
                padding-left: 30px;
                padding-right: 30px;
                padding-top: 44px;
                padding-bottom: 26px;
                spacing: 16px;

                Text { height: 36px; text: "设置"; color: AppColors.ink; font-size: 24px; font-weight: 700; vertical-alignment: center; }

                Rectangle {
                    border-width: 0px;
                    border-radius: 8px;
                    background: AppColors.surface;
                    drop-shadow-blur: 12px;
                    drop-shadow-offset-y: 2px;
                    drop-shadow-color: #1f29370a;

                if root.current-section == SettingsSection.general: VerticalLayout {
                    padding: 22px;
                    spacing: 0px;
                    Text { height: 38px; text: "通用"; color: AppColors.ink; font-size: 18px; font-weight: 650; }
                    SettingsRow { title: "登录时启动"; detail: "尚未开放"; }
                    SettingsRow { title: "在 Dock 中显示"; detail: "当前显示"; }
                    SettingsRow { title: "界面语言"; detail: "简体中文"; }
                    SettingsRow { title: "主题"; detail: "跟随系统"; }
                    SettingsRow { title: "自动检查更新"; detail: "尚未开放"; }
                    Rectangle { vertical-stretch: 1; background: transparent; }
                }

                if root.current-section == SettingsSection.shortcuts-audio: VerticalLayout {
                    padding: 22px;
                    spacing: 0px;
                    Text { height: 38px; text: "快捷键与音频"; color: AppColors.ink; font-size: 18px; font-weight: 650; }
                    SettingsRow { title: "主触发器"; detail: "右 Command"; }
                    Rectangle { height: 22px; background: transparent; }
                    Text { height: 30px; text: "音频"; color: AppColors.text-muted; font-size: 13px; font-weight: 650; vertical-alignment: center; }
                    Rectangle {
                        height: 82px;
                        background: transparent;

                        HorizontalLayout {
                            padding-left: 2px;
                            padding-right: 2px;
                            spacing: 18px;
                            cross-axis-alignment: center;

                            VerticalLayout {
                                spacing: 5px;
                                Text { text: "麦克风"; color: AppColors.ink; font-size: 14px; font-weight: 650; }
                                Text { text: "选择首选麦克风，以便 Saymore 捕捉您的声音。"; color: AppColors.text-muted; font-size: 12px; }
                            }
                            Rectangle { horizontal-stretch: 1; background: transparent; }
                            Rectangle {
                                width: 238px;
                                height: 42px;
                                border-width: 1px;
                                border-color: AppColors.border;
                                border-radius: 7px;
                                background: microphone-touch.has-hover ? AppColors.surface-subtle : AppColors.surface;
                                accessible-role: button;
                                accessible-label: "选择麦克风";

                                HorizontalLayout {
                                    padding-left: 13px;
                                    padding-right: 12px;
                                    spacing: 8px;
                                    cross-axis-alignment: center;
                                    Text { text: "自动检测（MacBook 麦克风）"; color: AppColors.text; font-size: 12px; overflow: elide; vertical-alignment: center; }
                                    Rectangle { horizontal-stretch: 1; background: transparent; }
                                    Text { text: "›"; color: AppColors.text-muted; font-size: 20px; vertical-alignment: center; }
                                }
                                microphone-touch := TouchArea { }
                            }
                        }
                        Rectangle { y: parent.height - 1px; height: 1px; background: AppColors.border; }
                    }
                    AudioToggleRow {
                        title: "交互声音";
                        detail: "为开始、停止等关键操作播放声音。";
                        checked <=> root.interaction-sounds-enabled;
                    }
                    AudioToggleRow {
                        title: "语音输入时静音";
                        detail: "在语音输入时自动静音其他活动音频。";
                        checked <=> root.mute-other-audio-enabled;
                    }
                    Rectangle { vertical-stretch: 1; background: transparent; }
                }

                if root.current-section == SettingsSection.delivery-permissions: VerticalLayout {
                    padding: 22px;
                    spacing: 12px;
                    Text { height: 38px; text: "投递与权限"; color: AppColors.ink; font-size: 18px; font-weight: 650; }
                    PermissionRow { title: "麦克风"; status: root.microphone-status; granted: root.microphone-authorized; action-label: "授权"; action-visible: !root.microphone-authorized; action => { root.request-microphone-authorization(); } }
                    PermissionRow { title: "辅助功能"; status: root.authorization-status; granted: root.authorized; action-label: "授权"; action-visible: !root.authorized; action => { root.request-authorization(); } }
                    Rectangle { vertical-stretch: 1; background: transparent; }
                }

                if root.current-section == SettingsSection.privacy-history: VerticalLayout {
                    padding: 22px;
                    spacing: 0px;
                    Text { height: 38px; text: "隐私与历史"; color: AppColors.ink; font-size: 18px; font-weight: 650; }
                    HorizontalLayout {
                        height: 58px; cross-axis-alignment: center;
                        Text { text: "本地历史"; color: #3b3f45; font-size: 13px; font-weight: 550; }
                        Rectangle { horizontal-stretch: 1; background: transparent; }
                        AppCheckBox { checked <=> root.history-enabled; toggled => { root.set-history-enabled(self.checked); } }
                    }
                    HorizontalLayout {
                        height: 58px; cross-axis-alignment: center;
                        Text { text: "保留期限"; color: #3b3f45; font-size: 13px; font-weight: 550; }
                        Rectangle { horizontal-stretch: 1; background: transparent; }
                        AppSelect {
                            width: 132px;
                            model: ["1 天", "7 天", "30 天", "永久"];
                            current-value <=> root.history-retention;
                            selected(value) => { root.set-history-retention(value); }
                        }
                    }
                    SettingsRow { title: "匿名使用统计"; detail: "关闭"; }
                    SettingsRow { title: "崩溃报告"; detail: "关闭"; }
                    Rectangle { vertical-stretch: 1; background: transparent; }
                }

                if root.current-section == SettingsSection.about-updates: VerticalLayout {
                    padding: 22px;
                    spacing: 0px;
                    Text { height: 38px; text: "关于与更新"; color: AppColors.ink; font-size: 18px; font-weight: 650; }
                    SettingsRow { title: "Saymore"; detail: "0.1.0"; }
                    SettingsRow { title: "许可证"; detail: "MIT OR Apache-2.0"; }
                    SettingsRow { title: "界面技术"; detail: "Made with Slint"; }
                    Rectangle { vertical-stretch: 1; background: transparent; }
                }
            }
        }
    }
    }

}
