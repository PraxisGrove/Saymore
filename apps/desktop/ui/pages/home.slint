import { AppColors } from "../color-system.slint";

component UsageMetric inherits Rectangle {
    in property <string> value;
    in property <string> unit;
    in property <string> label;
    background: transparent;

    metric-value := Text {
        x: 0px;
        y: 4px;
        text: root.value;
        color: AppColors.ink;
        font-size: 24px;
        font-weight: 700;
    }

    Text {
        x: metric-value.preferred-width + 11px;
        y: 20px;
        text: root.unit;
        color: AppColors.text-muted;
        font-size: 10px;
    }

    Text {
        x: 0px;
        y: 42px;
        text: root.label;
        color: AppColors.text-muted;
        font-size: 10px;
    }
}

component DayBar inherits Rectangle {
    in property <float> level;
    in property <string> label;
    in property <bool> highlighted;
    background: transparent;

    Rectangle {
        x: (parent.width - 24px) / 2;
        y: parent.height - self.height - 18px;
        width: 24px;
        height: root.level <= 0 ? 0px : max(4px, (parent.height - 28px) * root.level);
        border-radius: 6px;
        background: root.highlighted ? AppColors.brand : AppColors.chart-neutral;
    }

    Text {
        y: parent.height - 12px;
        width: parent.width;
        height: 12px;
        text: root.label;
        color: AppColors.text-muted;
        font-size: 9px;
        horizontal-alignment: center;
        vertical-alignment: top;
    }
}

export component HomePage inherits Rectangle {
    in property <bool> authorized;
    in property <string> authorization-status;
    in property <bool> microphone-authorized;
    in property <string> microphone-status;
    in property <bool> asr-configured;
    in property <bool> asr-config-error;
    in property <string> asr-config-status;
    in property <string> shortcut-label: "右 Command";
    in property <bool> shortcut-enabled: true;
    in property <bool> delivery-healthy: true;
    in property <string> delivery-status: "文本投递正常";
    in property <string> usage-total-minutes: "0";
    in property <string> usage-total-characters: "0";
    in property <string> usage-average-speed: "0";
    in property <[float]> usage-trend;
    in property <[string]> usage-day-labels;
    in property <int> usage-highlighted-day: -1;
    callback open-model-settings();
    callback open-microphone-settings();
    callback open-accessibility-settings();
    callback open-delivery-settings();

    private property <bool> microphone-issue: !root.microphone-authorized;
    private property <bool> model-issue: !root.asr-configured || root.asr-config-error;
    private property <bool> accessibility-issue: !root.authorized;
    private property <bool> delivery-issue: !root.delivery-healthy;
    private property <bool> healthy: !root.microphone-issue && !root.model-issue && !root.accessibility-issue && !root.delivery-issue;
    private property <length> status-height: root.healthy ? 54px : 78px;
    private property <length> overview-title-y: root.healthy ? 301px : 325px;
    private property <length> overview-y: root.healthy ? 329px : 353px;
    private property <string> issue-title: root.microphone-issue ? "需要麦克风权限"
        : root.model-issue ? (root.asr-config-error ? "语音模型配置错误" : "尚未配置语音模型")
        : root.accessibility-issue ? "需要辅助功能权限"
        : "文本投递需要检查";
    private property <string> issue-detail: root.microphone-issue ? root.microphone-status
        : root.model-issue ? root.asr-config-status
        : root.accessibility-issue ? "未授权时，识别结果无法自动投递到当前输入框。"
        : root.delivery-status;
    private property <string> issue-action: root.model-issue ? "前往模型设置"
        : root.delivery-issue && !root.accessibility-issue ? "检查投递设置"
        : "打开系统设置";

    background: transparent;

    Text {
        x: 0px;
        y: 43px;
        text: "解放双手，说出所想";
        color: AppColors.ink;
        font-size: 27px;
        font-weight: 700;
    }

    Rectangle {
        x: 0px;
        y: 99px;
        width: parent.width - 1px;
        height: 86px;
        border-radius: 12px;
        background: AppColors.surface;

        Text { x: 18px; y: 16px; text: "语音输入快捷键"; color: AppColors.ink; font-size: 14px; font-weight: 700; }
        Text { x: 18px; y: 42px; text: "当前设置"; color: AppColors.text-muted; font-size: 11px; }

        Rectangle {
            x: parent.width - 210px;
            y: 24px;
            width: 118px;
            height: 38px;
            border-radius: 8px;
            border-width: 1px;
            border-color: AppColors.border;
            background: AppColors.canvas;
            Text { text: root.shortcut-label; color: AppColors.text; font-size: 12px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; overflow: elide; }
        }

        Rectangle {
            x: parent.width - 82px;
            y: 24px;
            width: 66px;
            height: 38px;
            border-radius: 8px;
            background: root.shortcut-enabled ? AppColors.success-soft : AppColors.surface-subtle;
            Text { text: root.shortcut-enabled ? "已启用" : "未启用"; color: root.shortcut-enabled ? AppColors.success : AppColors.text-muted; font-size: 11px; font-weight: 650; horizontal-alignment: center; vertical-alignment: center; }
        }
    }

    Text { x: 0px; y: 199px; text: "配置状态"; color: AppColors.text; font-size: 14px; font-weight: 650; }

    Rectangle {
        x: 0px;
        y: 223px;
        width: parent.width - 1px;
        height: root.status-height;
        border-radius: 10px;
        background: root.healthy ? AppColors.sidebar : root.model-issue ? AppColors.warning-soft : AppColors.surface-subtle;

        if root.healthy: Text {
            x: 20px;
            y: 18px;
            text: "模型已连接 · 麦克风已授权 · 文本投递正常";
            color: AppColors.text;
            font-size: 12px;
            font-weight: 600;
        }

        if root.healthy: Rectangle {
            x: parent.width - 100px;
            y: 12px;
            width: 84px;
            height: 30px;
            border-radius: 7px;
            background: AppColors.success-soft;
            Text { text: "●  全部正常"; color: AppColors.success; font-size: 10px; font-weight: 650; horizontal-alignment: center; vertical-alignment: center; }
        }

        if !root.healthy: VerticalLayout {
            x: 20px;
            y: 13px;
            width: parent.width - 188px;
            height: 52px;
            spacing: 4px;
            Text { text: root.issue-title; color: AppColors.ink; font-size: 13px; font-weight: 650; overflow: elide; }
            Text { text: root.issue-detail; color: AppColors.text-muted; font-size: 11px; overflow: elide; }
        }

        if !root.healthy: Rectangle {
            x: parent.width - 152px;
            y: 20px;
            width: 136px;
            height: 38px;
            border-radius: 8px;
            background: action-area.has-hover ? AppColors.brand-strong : AppColors.brand;
            accessible-role: button;
            accessible-label: root.issue-action;
            accessible-action-default => {
                if root.microphone-issue { root.open-microphone-settings(); }
                else if root.model-issue { root.open-model-settings(); }
                else if root.accessibility-issue { root.open-accessibility-settings(); }
                else { root.open-delivery-settings(); }
            }
            Text { text: root.issue-action; color: #ffffff; font-size: 12px; font-weight: 650; horizontal-alignment: center; vertical-alignment: center; }
            action-area := TouchArea {
                mouse-cursor: pointer;
                clicked => {
                    if root.microphone-issue { root.open-microphone-settings(); }
                    else if root.model-issue { root.open-model-settings(); }
                    else if root.accessibility-issue { root.open-accessibility-settings(); }
                    else { root.open-delivery-settings(); }
                }
            }
        }
    }

    Text { x: 0px; y: root.overview-title-y; text: "使用概览"; color: AppColors.text; font-size: 14px; font-weight: 650; }

    Rectangle {
        x: 0px;
        y: root.overview-y;
        width: parent.width - 1px;
        height: max(160px, parent.height - root.overview-y - 3px);
        border-radius: 12px;
        background: AppColors.surface;

        Text { x: 20px; y: 16px; text: "累计数据"; color: AppColors.text-muted; font-size: 11px; font-weight: 600; }

        private property <length> metric-step: (self.width - 62px) / 3;
        UsageMetric { x: 20px; y: 32px; width: parent.metric-step - 30px; height: 78px; value: root.usage-total-minutes; unit: "分钟"; label: "累计口述"; }
        Rectangle { x: 20px + parent.metric-step - 30px; y: 32px; width: 1px; height: 68px; background: AppColors.border; }
        UsageMetric { x: 20px + parent.metric-step; y: 32px; width: parent.metric-step - 30px; height: 78px; value: root.usage-total-characters; unit: "字"; label: "累计字数"; }
        Rectangle { x: 20px + parent.metric-step * 2 - 30px; y: 32px; width: 1px; height: 68px; background: AppColors.border; }
        UsageMetric { x: 20px + parent.metric-step * 2; y: 32px; width: parent.metric-step - 30px; height: 78px; value: root.usage-average-speed; unit: "字/分"; label: "平均速度"; }

        Text { x: 20px; y: 116px; text: "最近 7 天趋势"; color: AppColors.text-muted; font-size: 11px; font-weight: 600; }

        HorizontalLayout {
            x: 40px;
            y: 144px;
            width: parent.width - 104px;
            height: max(36px, parent.height - 154px);
            spacing: 0px;
            alignment: space-between;

            for label[index] in root.usage-day-labels: DayBar {
                width: 48px;
                level: root.usage-trend[index];
                label: label;
                highlighted: index == root.usage-highlighted-day;
            }
        }
    }
}
