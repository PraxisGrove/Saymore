import { ScrollView } from "std-widgets.slint";
import { AppColors } from "../color-system.slint";

export enum HistoryRetentionOption { never, one-day, seven-days, thirty-days, forever }

export struct HistoryListItem {
    id: string,
    text: string,
    preview-text: string,
    time: string,
    duration: string,
    input-status: string,
    polish-status: string,
    asr-model: string,
    llm-model: string,
}

export struct HistoryGroup {
    title: string,
    items: [HistoryListItem],
}

component RetentionOptionButton inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    callback activated();
    height: 38px;
    border-radius: 7px;
    background: root.selected ? AppColors.selected : (option-touch.has-hover ? AppColors.surface-warm : transparent);
    Text {
        x: 8px;
        width: parent.width - 16px;
        text: root.label;
        color: AppColors.ink;
        font-size: 12px;
        font-weight: root.selected ? 700 : 400;
        vertical-alignment: center;
    }
    option-touch := TouchArea { mouse-cursor: pointer; clicked => { root.activated(); } }
}

component HistoryIconButton inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    in property <bool> danger: false;
    in property <bool> enabled: true;
    in property <bool> success: false;
    out property <bool> has-hover: touch.has-hover;
    callback activated();
    width: 34px;
    height: 34px;
    border-radius: 7px;
    background: root.success ? AppColors.success-soft : (touch.has-hover ? (root.danger ? AppColors.danger-soft : AppColors.surface-subtle) : transparent);
    animate background { duration: 140ms; easing: ease-out; }
    accessible-role: button;
    accessible-label: root.label;
    accessible-action-default => { if root.enabled { root.activated(); } }
    Image {
        width: 16px;
        height: 16px;
        x: 9px;
        y: 9px;
        source: root.icon;
        colorize: root.danger ? AppColors.danger : AppColors.text-muted;
        opacity: root.success ? 0 : 1;
        animate opacity { duration: 120ms; easing: ease-out; }
    }
    Image {
        width: 16px;
        height: 16px;
        x: 9px;
        y: 9px;
        source: @image-url("../../icons/lucide/check.svg");
        colorize: AppColors.success;
        opacity: root.success ? 1 : 0;
        animate opacity { duration: 120ms; easing: ease-out; }
    }
    touch := TouchArea { enabled: root.enabled; mouse-cursor: root.enabled ? pointer : default; clicked => { root.activated(); } }
}

component QuietButton inherits Rectangle {
    in property <string> label;
    in property <bool> primary: false;
    in property <bool> danger: false;
    in property <bool> success: false;
    callback activated();
    height: 36px;
    border-radius: 7px;
    background: root.success ? AppColors.success : root.primary
        ? (root.danger ? (touch.has-hover ? AppColors.danger-strong : AppColors.danger) : (touch.has-hover ? AppColors.brand-hover : AppColors.brand))
        : (touch.has-hover ? AppColors.selected : AppColors.surface-subtle);
    animate background { duration: 140ms; easing: ease-out; }
    if root.success: Image { x: 28px; y: 10px; width: 16px; height: 16px; source: @image-url("../../icons/lucide/check.svg"); colorize: AppColors.on-brand; }
    Text { x: root.success ? 48px : 0px; width: root.success ? parent.width - 48px : parent.width; text: root.label; color: root.success || root.primary ? AppColors.on-brand : (root.danger ? AppColors.danger : AppColors.text); font-size: 12px; font-weight: 650; horizontal-alignment: root.success ? left : center; vertical-alignment: center; }
    touch := TouchArea { mouse-cursor: pointer; clicked => { root.activated(); } }
}

component StateIcon inherits Rectangle {
    in property <image> source;
    in property <length> size: 30px;
    height: root.size;
    background: transparent;
    Image { x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; width: root.size; height: root.size; source: root.source; }
}

export component HistoryDialog inherits Rectangle {
    in-out property <bool> detail-visible: false;
    in-out property <bool> clear-confirmation-visible: false;
    in-out property <bool> reset-confirmation-visible: false;
    in property <string> selected-id: "";
    in property <string> selected-text: "";
    in property <string> selected-time: "";
    in property <string> selected-duration: "";
    in property <string> selected-input: "";
    in property <string> selected-polish: "";
    in property <string> selected-asr: "";
    in property <string> selected-llm: "";
    callback copy(string);
    callback delete-record(string);
    callback clear-all();
    callback reset();

    property <bool> active: root.detail-visible || root.clear-confirmation-visible || root.reset-confirmation-visible;
    property <bool> detail-copied: false;
    background: AppColors.scrim;
    z: 100;
    opacity: self.active ? 1 : 0;
    animate opacity { duration: 160ms; easing: ease-out; }
    TouchArea {
        enabled: root.active;
        clicked => {
            root.detail-visible = false;
            root.clear-confirmation-visible = false;
            root.reset-confirmation-visible = false;
        }
    }
    Timer { interval: 1500ms; running: root.detail-copied; triggered => { root.detail-copied = false; } }
    Rectangle {
        width: root.detail-visible ? min(560px, parent.width - 32px) : (root.reset-confirmation-visible ? min(500px, parent.width - 32px) : 350px);
        height: root.detail-visible ? min(440px, parent.height - 32px) : (root.reset-confirmation-visible ? 250px : 210px);
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        border-radius: 8px;
        background: AppColors.surface;

        if root.clear-confirmation-visible: VerticalLayout {
            padding: 24px;
            spacing: 16px;
            Text { text: @tr("history.clear.title" => "Clear all history?"); color: AppColors.ink; font-size: 18px; font-weight: 700; }
            Text { text: @tr("history.clear.detail" => "All records will be permanently deleted from this device. This cannot be undone."); color: AppColors.text-muted; font-size: 12px; wrap: word-wrap; }
            HorizontalLayout {
                alignment: end;
                spacing: 10px;
                QuietButton { width: 78px; label: @tr("common.cancel" => "Cancel"); activated => { root.clear-confirmation-visible = false; } }
                QuietButton { width: 92px; label: @tr("history.clear.action" => "Clear"); primary: true; danger: true; activated => { root.clear-confirmation-visible = false; root.clear-all(); } }
            }
        }

        if root.reset-confirmation-visible: VerticalLayout {
            padding: 24px;
            spacing: 15px;
            Text { text: @tr("history.reset.title" => "Reset history?"); color: AppColors.ink; font-size: 18px; font-weight: 700; }
            Text { text: @tr("history.reset.detail" => "Existing history will be permanently deleted and cannot be recovered."); color: AppColors.text; font-size: 12px; }
            Text { text: @tr("history.reset.unaffected" => "Your dictionary, model configuration, and other settings will not be affected."); color: AppColors.text-muted; font-size: 11px; }
            HorizontalLayout {
                alignment: end;
                spacing: 10px;
                QuietButton { width: 86px; label: @tr("common.cancel" => "Cancel"); activated => { root.reset-confirmation-visible = false; } }
                QuietButton { width: 108px; label: @tr("history.reset.action" => "Delete and reset"); primary: true; danger: true; activated => { root.reset-confirmation-visible = false; root.reset(); } }
            }
        }

        if root.detail-visible: Rectangle {
            x: 24px;
            y: 20px;
            width: parent.width - 48px;
            height: parent.height - 40px;
            Text { x: 0px; y: 0px; text: @tr("history.detail.title" => "Record details"); color: AppColors.ink; font-size: 18px; font-weight: 700; }
            HistoryIconButton { x: parent.width - 34px; y: -5px; icon: @image-url("../../icons/lucide/x.svg"); label: @tr("common.close" => "Close"); activated => { root.detail-visible = false; } }
            Text { x: 0px; y: 36px; text: root.selected-time; color: AppColors.text-muted; font-size: 10px; }
            Text { x: 0px; y: 68px; text: @tr("history.detail.content" => "Content"); color: AppColors.text; font-size: 11px; font-weight: 650; }
            Rectangle {
                x: 0px;
                y: 90px;
                width: parent.width;
                height: 105px;
                border-radius: 7px;
                background: AppColors.surface-warm;
                detail-scroll := ScrollView {
                    x: 16px;
                    y: 14px;
                    width: parent.width - 32px;
                    height: parent.height - 28px;
                    viewport-width: self.width;
                    viewport-height: max(self.height, detail-copy.preferred-height);
                    vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                    horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                    detail-copy := Text {
                        width: detail-scroll.viewport-width;
                        height: self.preferred-height;
                        text: root.selected-text;
                        color: AppColors.ink;
                        font-size: 13px;
                        wrap: word-wrap;
                    }
                }
            }
            Text { x: 0px; y: 216px; text: @tr("history.detail.record-info" => "Record information"); color: AppColors.text; font-size: 11px; font-weight: 650; }
            Rectangle {
                x: 0px;
                y: 238px;
                width: parent.width;
                height: 96px;
                border-radius: 7px;
                background: AppColors.surface-warm;
                Text { x: 16px; y: 13px; text: @tr("history.detail.summary" => "{}  ·  {}  ·  {}", root.selected-duration, root.selected-input, root.selected-polish); color: AppColors.text; font-size: 10px; }
                Text { x: 16px; y: 40px; text: @tr("history.detail.asr-model" => "Speech model"); color: AppColors.text-muted; font-size: 10px; }
                Text { x: 100px; y: 40px; width: parent.width - 116px; text: root.selected-asr; color: AppColors.text; font-size: 10px; overflow: elide; }
                Text { x: 16px; y: 66px; text: @tr("history.detail.llm-model" => "Polishing model"); color: AppColors.text-muted; font-size: 10px; }
                Text { x: 100px; y: 66px; width: parent.width - 116px; text: root.selected-llm; color: AppColors.text; font-size: 10px; overflow: elide; }
            }
            Rectangle {
                x: 0px;
                y: parent.height - 36px;
                width: 88px;
                height: 36px;
                background: detail-delete-touch.has-hover ? AppColors.danger-soft : transparent;
                border-radius: 7px;
                Text { text: @tr("history.delete-record" => "Delete record"); color: AppColors.danger; font-size: 11px; font-weight: 650; horizontal-alignment: center; vertical-alignment: center; }
                detail-delete-touch := TouchArea { mouse-cursor: pointer; clicked => { root.detail-visible = false; root.delete-record(root.selected-id); } }
            }
            QuietButton { x: parent.width - 110px; y: parent.height - 36px; width: 110px; label: root.detail-copied ? @tr("common.copied" => "Copied") : @tr("history.copy-content" => "Copy content"); primary: true; success: root.detail-copied; activated => { root.detail-copied = true; root.copy(root.selected-id); } }
        }
    }
}

export component HistoryPage inherits Rectangle {
    in property <[HistoryGroup]> groups;
    in property <string> status-text: "";
    in property <bool> undo-visible: false;
    in property <bool> has-more: false;
    in property <bool> locked: false;
    in property <bool> loading: false;
    in property <bool> load-failed: false;
    in property <HistoryRetentionOption> retention: HistoryRetentionOption.seven-days;
    callback refresh();
    callback search(string);
    callback load-more();
    callback copy(string);
    callback delete-record(string);
    callback undo-delete();
    callback retention-selected(HistoryRetentionOption);
    callback show-detail(HistoryListItem);
    callback show-clear-confirmation();
    callback show-reset-confirmation();

    property <bool> compact: root.width < 650px;
    property <length> controls-y: root.compact ? 66px : 43px;
    property <length> state-y: root.compact ? 130px : 94px;
    property <length> list-y: root.compact ? 138px : 112px;
    property <bool> retention-open: false;
    property <bool> more-open: false;
    property <string> query: "";
    property <string> copied-id: "";
    property <bool> search-active: search-input.has-focus || !root.query.is-empty;
    property <length> search-width: root.search-active ? min(280px, root.width - 208px) : 38px;
    property <bool> status-visible: !root.status-text.is-empty;
    property <string> retention-label: root.retention == HistoryRetentionOption.never ? @tr("history.retention.never" => "Never save")
        : root.retention == HistoryRetentionOption.one-day ? @tr("history.retention.one-day" => "Keep for 24 hours")
        : root.retention == HistoryRetentionOption.thirty-days ? @tr("history.retention.thirty-days" => "Keep for 1 month")
        : root.retention == HistoryRetentionOption.forever ? @tr("history.retention.forever" => "Keep forever")
        : @tr("history.retention.seven-days" => "Keep for 1 week");

    background: AppColors.canvas;
    page-focus := FocusScope { width: 0px; height: 0px; }
    TouchArea { mouse-cursor: default; clicked => { page-focus.focus(); root.retention-open = false; root.more-open = false; } }
    changed status-text => { root.status-visible = !root.status-text.is-empty; }
    Timer { interval: 4s; running: root.status-visible; triggered => { root.status-visible = false; } }
    Timer { interval: 1500ms; running: !root.copied-id.is-empty; triggered => { root.copied-id = ""; } }

    Text {
        x: 0px;
        y: root.compact ? 22px : 42px;
        text: @tr("history.title" => "History");
        color: AppColors.ink;
        font-size: 27px;
        font-weight: 700;
        letter-spacing: 0px;
    }

    search-box := Rectangle {
        x: root.width - 38px - 8px - 146px - 8px - self.width;
        y: root.controls-y;
        width: root.search-width;
        height: 38px;
        border-radius: 8px;
        border-width: root.search-active ? 1px : 0px;
        border-color: AppColors.brand;
        background: root.search-active ? AppColors.surface : AppColors.surface-subtle;
        animate width { duration: 200ms; easing: ease-out; }
        Image { x: 11px; y: 10px; width: 18px; height: 18px; source: @image-url("../../icons/lucide/search.svg"); }
        if root.search-active && root.query.is-empty: Text {
            x: 40px; width: parent.width - 50px; text: @tr("history.search.placeholder" => "Search history"); color: AppColors.text-muted; font-size: 12px; vertical-alignment: center;
        }
        search-input := TextInput {
            x: 38px; width: max(0px, parent.width - 48px); text <=> root.query; color: AppColors.text; font-size: 12px; vertical-alignment: center;
            changed text => { root.search(root.query); }
        }
        TouchArea { width: root.search-active ? 34px : parent.width; mouse-cursor: pointer; clicked => { search-input.focus(); } }
    }

    retention-button := Rectangle {
        x: root.width - 38px - 8px - 146px;
        y: root.controls-y;
        width: 146px;
        height: 38px;
        border-radius: 8px;
        background: retention-touch.has-hover ? AppColors.selected : AppColors.surface-subtle;
        Text { x: 18px; width: parent.width - 48px; text: root.retention-label; color: AppColors.text; font-size: 12px; font-weight: 650; vertical-alignment: center; }
        Image { x: parent.width - 27px; y: 13px; width: 12px; height: 12px; source: root.retention-open ? @image-url("../../icons/lucide/chevron-up.svg") : @image-url("../../icons/lucide/chevron-down.svg"); }
        retention-touch := TouchArea { mouse-cursor: pointer; clicked => { root.retention-open = !root.retention-open; root.more-open = false; } }
    }

    if root.groups.length > 0 && !root.loading && !root.load-failed && !root.locked: HistoryIconButton {
        x: root.width - 38px;
        y: root.controls-y + 2px;
        icon: @image-url("../../icons/lucide/ellipsis.svg");
        label: @tr("common.more-actions" => "More actions");
        activated => { root.more-open = !root.more-open; root.retention-open = false; }
    }

    if !root.compact && !root.loading && !root.load-failed && !root.locked && root.query.is-empty && root.groups.length > 0: HorizontalLayout {
        x: 0px; y: 88px; height: 20px; spacing: 7px; cross-axis-alignment: center;
        Image { width: 14px; height: 14px; source: @image-url("../../icons/lucide/lock-keyhole.svg"); }
        Text { text: @tr("history.local-only" => "History is stored only on this device"); color: AppColors.text-muted; font-size: 10px; vertical-alignment: center; }
    }

    if !root.loading && !root.load-failed && !root.locked && root.groups.length > 0: ScrollView {
        x: 0px;
        y: root.list-y;
        width: parent.width;
        height: parent.height - root.list-y - 8px;
        vertical-scrollbar-policy: ScrollBarPolicy.always-off;
        horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
        VerticalLayout {
            spacing: 12px;
            for group in root.groups: VerticalLayout {
                spacing: 6px;
                Text { height: 18px; text: group.title; color: AppColors.text; font-size: 12px; vertical-alignment: center; }
                Rectangle {
                    height: group.items.length * 58px;
                    border-radius: 8px;
                    background: AppColors.surface;
                    VerticalLayout {
                        spacing: 0px;
                        for item[index] in group.items: history-row := Rectangle {
                            property <bool> hovered: row-touch.has-hover || copy-button.has-hover || delete-button.has-hover;
                            property <bool> copied: root.copied-id == item.id;
                            height: 58px;
                            background: self.hovered ? AppColors.brand-soft : transparent;
                            animate background { duration: 120ms; easing: ease-out; }
                            Rectangle {
                                x: 0px;
                                y: 0px;
                                width: 3px;
                                height: parent.height;
                                background: AppColors.brand;
                                opacity: parent.hovered ? 1 : 0;
                                animate opacity { duration: 120ms; easing: ease-out; }
                            }
                            if index > 0: Rectangle { x: 18px; y: 0px; width: parent.width - 36px; height: 1px; background: AppColors.border; }
                            row-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.show-detail(item); }
                            }
                            Text { x: 18px; width: 72px; text: item.time; color: AppColors.text-muted; font-size: 10px; font-weight: 650; vertical-alignment: center; }
                            Text { x: 90px; y: 10px; width: parent.width - 108px - (parent.hovered ? 78px : 0px); height: 20px; text: item.preview-text; color: AppColors.ink; font-size: 12px; font-weight: 650; overflow: elide; vertical-alignment: center; }
                            Text { x: 90px; y: 32px; width: parent.width - 108px; height: 16px; text: @tr("history.item.summary" => "{}  ·  {}  ·  {}", item.duration, item.input-status, item.polish-status); color: AppColors.text-muted; font-size: 9px; vertical-alignment: center; }
                            HorizontalLayout {
                                x: parent.width - 82px; y: 12px; width: 68px; height: 34px; spacing: 0px;
                                opacity: parent.hovered ? 1 : 0;
                                animate opacity { duration: 140ms; easing: ease-out; }
                                copy-button := HistoryIconButton { icon: @image-url("../../icons/lucide/copy.svg"); label: history-row.copied ? @tr("common.copied" => "Copied") : @tr("history.copy-content" => "Copy content"); success: history-row.copied; activated => { root.copied-id = item.id; root.copy(item.id); } }
                                delete-button := HistoryIconButton { icon: @image-url("../../icons/lucide/trash-2.svg"); label: @tr("history.delete-record" => "Delete record"); danger: true; activated => { root.delete-record(item.id); } }
                            }
                        }
                    }
                }
            }
            if root.has-more: Rectangle {
                height: 36px; background: transparent;
                Text { text: @tr("history.load-more" => "Load more"); color: AppColors.brand; font-size: 11px; font-weight: 650; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { mouse-cursor: pointer; clicked => { root.load-more(); } }
            }
        }
    }

    if root.loading || root.load-failed || root.locked || (!root.loading && root.groups.length == 0): Rectangle {
        x: 0px; y: root.state-y; width: parent.width; height: parent.height - root.state-y; border-radius: 8px; background: AppColors.surface;
        VerticalLayout {
            x: 24px; y: 0px; width: parent.width - 48px; height: parent.height; alignment: center; spacing: 13px;
            if root.loading: StateIcon { size: 28px; source: @image-url("../../icons/lucide/refresh-cw.svg"); }
            if root.loading: Text { text: @tr("history.loading.title" => "Loading history"); color: AppColors.ink; font-size: 16px; horizontal-alignment: center; }
            if root.loading: Text { text: @tr("history.loading.detail" => "Reading content saved on this device"); color: AppColors.text-muted; font-size: 11px; horizontal-alignment: center; }
            if root.load-failed: StateIcon { size: 28px; source: @image-url("../../icons/lucide/circle-alert.svg"); }
            if root.load-failed: Text { text: @tr("history.load-failed.title" => "Local history is unavailable"); color: AppColors.ink; font-size: 16px; horizontal-alignment: center; }
            if root.load-failed: Rectangle { width: 84px; height: 28px; background: transparent; Text { text: @tr("common.reload" => "Reload ↗"); color: AppColors.brand; font-size: 11px; font-weight: 650; horizontal-alignment: center; vertical-alignment: center; } TouchArea { mouse-cursor: pointer; clicked => { root.refresh(); } } }
            if root.locked: StateIcon { source: @image-url("../../icons/lucide/lock-keyhole.svg"); }
            if root.locked: Text { text: @tr("history.locked.title" => "History is locked"); color: AppColors.ink; font-size: 16px; font-weight: 650; horizontal-alignment: center; }
            if root.locked: Text { text: @tr("history.locked.detail" => "The history key is unavailable. Settings and dictionary remain available."); color: AppColors.text-muted; font-size: 11px; horizontal-alignment: center; }
            if root.locked: QuietButton { width: 230px; label: @tr("history.locked.reset-action" => "Delete old history and reset"); primary: true; danger: true; activated => { root.show-reset-confirmation(); } }
            if !root.loading && !root.load-failed && !root.locked && root.query.is-empty: StateIcon { source: @image-url("../../icons/lucide/history.svg"); }
            if !root.loading && !root.load-failed && !root.locked && root.query.is-empty: Text { text: @tr("history.empty.title" => "No history yet"); color: AppColors.ink; font-size: 16px; horizontal-alignment: center; }
            if !root.loading && !root.load-failed && !root.locked && root.query.is-empty: Text { text: @tr("history.empty.detail" => "Completed voice input will be saved here securely"); color: AppColors.text-muted; font-size: 11px; horizontal-alignment: center; }
            if !root.loading && !root.load-failed && !root.locked && !root.query.is-empty: StateIcon { source: @image-url("../../icons/lucide/search.svg"); }
            if !root.loading && !root.load-failed && !root.locked && !root.query.is-empty: Text { text: @tr("history.no-results.title" => "No results for “{}”", root.query); color: AppColors.ink; font-size: 16px; horizontal-alignment: center; }
            if !root.loading && !root.load-failed && !root.locked && !root.query.is-empty: Text { text: @tr("history.no-results.detail" => "Try a shorter search term or check your spelling"); color: AppColors.text-muted; font-size: 11px; horizontal-alignment: center; }
        }
    }

    if root.retention-open || root.more-open: Rectangle {
        x: 0px; y: 0px; width: parent.width; height: parent.height; background: transparent; z: 35;
        TouchArea { mouse-cursor: default; clicked => { root.retention-open = false; root.more-open = false; } }
    }

    if root.retention-open: Rectangle {
        x: root.width - 38px - 8px - 146px; y: root.controls-y + 46px; width: 146px; height: 206px; border-radius: 8px; background: AppColors.surface; z: 40;
        drop-shadow-blur: 18px; drop-shadow-offset-y: 5px; drop-shadow-color: AppColors.shadow;
        VerticalLayout { padding: 8px; spacing: 0px;
            RetentionOptionButton { label: @tr("history.retention.option.never" => "Never"); selected: root.retention == HistoryRetentionOption.never; activated => { root.retention-open = false; root.retention-selected(HistoryRetentionOption.never); } }
            RetentionOptionButton { label: @tr("history.retention.option.one-day" => "24 hours"); selected: root.retention == HistoryRetentionOption.one-day; activated => { root.retention-open = false; root.retention-selected(HistoryRetentionOption.one-day); } }
            RetentionOptionButton { label: @tr("history.retention.option.seven-days" => "1 week"); selected: root.retention == HistoryRetentionOption.seven-days; activated => { root.retention-open = false; root.retention-selected(HistoryRetentionOption.seven-days); } }
            RetentionOptionButton { label: @tr("history.retention.option.thirty-days" => "1 month"); selected: root.retention == HistoryRetentionOption.thirty-days; activated => { root.retention-open = false; root.retention-selected(HistoryRetentionOption.thirty-days); } }
            RetentionOptionButton { label: @tr("history.retention.option.forever" => "Forever"); selected: root.retention == HistoryRetentionOption.forever; activated => { root.retention-open = false; root.retention-selected(HistoryRetentionOption.forever); } }
        }
    }

    if root.more-open: Rectangle {
        x: root.width - 160px; y: root.controls-y + 46px; width: 160px; height: 86px; border-radius: 8px; background: AppColors.surface; z: 40;
        drop-shadow-blur: 18px; drop-shadow-offset-y: 5px; drop-shadow-color: AppColors.shadow;
        VerticalLayout { padding: 8px; spacing: 0px;
            Rectangle { height: 35px; border-radius: 6px; background: refresh-touch.has-hover ? AppColors.surface-warm : transparent; accessible-role: button; accessible-label: @tr("history.refresh" => "Refresh history"); accessible-action-default => { root.more-open = false; root.refresh(); } Image { x: 8px; y: 9px; width: 16px; height: 16px; source: @image-url("../../icons/lucide/refresh-cw.svg"); } Text { x: 34px; text: @tr("history.refresh" => "Refresh history"); color: AppColors.text; font-size: 12px; vertical-alignment: center; } refresh-touch := TouchArea { mouse-cursor: pointer; clicked => { root.more-open = false; root.refresh(); } } }
            Rectangle { height: 35px; border-radius: 6px; background: clear-touch.has-hover ? AppColors.danger-soft : transparent; accessible-role: button; accessible-label: @tr("history.clear-all" => "Clear all history"); accessible-action-default => { root.more-open = false; root.show-clear-confirmation(); } Image { x: 8px; y: 9px; width: 16px; height: 16px; source: @image-url("../../icons/lucide/trash-2.svg"); } Text { x: 34px; text: @tr("history.clear-all" => "Clear all history"); color: AppColors.danger; font-size: 12px; vertical-alignment: center; } clear-touch := TouchArea { mouse-cursor: pointer; clicked => { root.more-open = false; root.show-clear-confirmation(); } } }
        }
    }

    Rectangle {
        x: root.width - self.width - 8px;
        y: root.status-visible ? (root.undo-visible ? root.height - 108px : root.height - 50px) : root.height + 4px;
        width: min(320px, root.width - 16px);
        height: 40px;
        border-radius: 7px;
        background: AppColors.ink;
        z: 60;
        opacity: root.status-visible ? 1 : 0;
        animate y { duration: 180ms; easing: ease-out; }
        animate opacity { duration: 160ms; easing: ease-out; }
        drop-shadow-blur: 12px; drop-shadow-offset-y: 3px; drop-shadow-color: AppColors.shadow;
        Image { x: 12px; y: 12px; width: 16px; height: 16px; source: @image-url("../../icons/lucide/circle-alert.svg"); colorize: AppColors.inverse-text; }
        Text { x: 36px; width: parent.width - 72px; text: root.status-text; color: AppColors.inverse-text; font-size: 11px; vertical-alignment: center; overflow: elide; }
        Rectangle { x: parent.width - 34px; y: 3px; width: 34px; height: 34px; border-radius: 7px; background: close-touch.has-hover ? AppColors.inverse-hover : transparent;
            Image { x: 9px; y: 9px; width: 16px; height: 16px; source: @image-url("../../icons/lucide/x.svg"); colorize: AppColors.inverse-text; }
            close-touch := TouchArea { mouse-cursor: pointer; clicked => { root.status-visible = false; } }
        }
    }

    Rectangle {
        x: (parent.width - 240px) / 2; y: root.undo-visible ? parent.height - 58px : parent.height + 4px; width: 240px; height: 48px; border-radius: 7px; background: AppColors.ink; z: 60;
        opacity: root.undo-visible ? 1 : 0;
        animate y { duration: 180ms; easing: ease-out; }
        animate opacity { duration: 160ms; easing: ease-out; }
        drop-shadow-blur: 12px; drop-shadow-offset-y: 3px; drop-shadow-color: AppColors.shadow;
        Text { x: 16px; width: 130px; text: @tr("history.deleted-one" => "1 record deleted"); color: AppColors.inverse-text; font-size: 11px; vertical-alignment: center; }
        Rectangle { x: 158px; y: 11px; width: 1px; height: 26px; background: AppColors.inverse-divider; }
        Rectangle { x: 160px; width: 80px; height: 48px; background: transparent; Text { text: @tr("common.undo" => "Undo"); color: AppColors.inverse-text; font-size: 11px; font-weight: 650; horizontal-alignment: center; vertical-alignment: center; } TouchArea { enabled: root.undo-visible; mouse-cursor: root.undo-visible ? pointer : default; clicked => { root.undo-delete(); } } }
    }

}
