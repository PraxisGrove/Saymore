import { AsrProvider, LlmProvider } from "../components.slint";
import { AppColors } from "../color-system.slint";
import { ScrollView } from "std-widgets.slint";

component ModelTab inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    callback activated();
    width: max(56px, tab-label.preferred-width);
    height: 32px;
    background: transparent;
    accessible-role: button;
    accessible-label: root.label;
    accessible-action-default => { root.activated(); }

    tab-label := Text {
        y: 0px;
        text: root.label;
        color: root.selected ? AppColors.ink : AppColors.text-muted;
        font-size: 14px;
        font-weight: root.selected ? 700 : 600;
    }
    if root.selected: Rectangle {
        y: 28px;
        width: parent.width;
        height: 3px;
        border-radius: 2px;
        background: AppColors.brand;
    }
    TouchArea { mouse-cursor: pointer; clicked => { root.activated(); } }
}

component ModelActionButton inherits Rectangle {
    in property <string> label;
    in property <bool> primary;
    in property <bool> enabled: true;
    in property <bool> completed: false;
    callback activated();
    width: 110px;
    height: 40px;
    border-radius: 8px;
    background: !root.enabled ? (root.completed ? AppColors.success-soft : AppColors.surface-muted)
        : root.primary ? (action-touch.has-hover ? AppColors.brand-hover : AppColors.brand)
        : action-touch.pressed ? AppColors.chart-neutral
        : action-touch.has-hover ? AppColors.selected : AppColors.surface-subtle;
    opacity: !root.enabled ? (root.completed ? 1 : 0.55) : action-touch.pressed ? 0.84 : 1;
    animate background { duration: 100ms; easing: ease-out; }
    animate opacity { duration: 70ms; easing: ease-out; }
    accessible-role: button;
    accessible-label: root.label;
    accessible-enabled: root.enabled;
    accessible-action-default => { if root.enabled { root.activated(); } }
    Text {
        text: root.label;
        color: !root.enabled ? (root.completed ? AppColors.success : AppColors.text-muted) : root.primary ? AppColors.on-brand : AppColors.text;
        font-size: 12px;
        font-weight: 650;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    action-touch := TouchArea { enabled: root.enabled; mouse-cursor: root.enabled ? pointer : default; clicked => { root.activated(); } }
}

component LlmEnableSwitch inherits Rectangle {
    in property <bool> checked;
    callback activated();

    width: 28px;
    height: 16px;
    border-radius: 8px;
    background: root.checked ? AppColors.brand
        : switch-touch.has-hover ? AppColors.selected : AppColors.chart-neutral;
    opacity: switch-touch.pressed ? 0.84 : 1;
    animate background { duration: 140ms; easing: ease-out; }
    animate opacity { duration: 70ms; easing: ease-out; }
    accessible-role: switch;
    accessible-label: @tr("models.polishing.enable.accessible-label" => "Enable text polishing");
    accessible-checked: root.checked;
    accessible-action-default => { root.activated(); }

    Rectangle {
        x: root.checked ? 14px : 2px;
        y: 2px;
        width: 12px;
        height: 12px;
        border-radius: 6px;
        background: AppColors.surface;
        animate x { duration: 160ms; easing: ease-out; }
    }
    switch-touch := TouchArea { mouse-cursor: pointer; clicked => { root.activated(); } }
}

component ChevronButton inherits Rectangle {
    in property <bool> open;
    callback activated();
    width: 32px;
    height: 32px;
    background: transparent;
    Image {
        x: 9px;
        y: 9px;
        width: 14px;
        height: 14px;
        source: root.open ? @image-url("../../icons/lucide/chevron-up.svg") : @image-url("../../icons/lucide/chevron-down.svg");
        colorize: AppColors.text-muted;
    }
    TouchArea { mouse-cursor: pointer; clicked => { root.activated(); } }
}

component ServiceCard inherits Rectangle {
    in property <image> icon;
    in property <string> name;
    in property <string> detail;
    in property <string> status;
    in property <bool> healthy;
    in property <bool> open;
    callback activated();
    height: 72px;
    border-radius: 12px;
    background: AppColors.surface;

    Image { x: 18px; y: 20px; width: 20px; height: 20px; source: root.icon; colorize: AppColors.ink; }
    Text { x: 50px; y: 13px; text: root.name; color: AppColors.ink; font-size: 14px; font-weight: 650; }
    Text { x: 50px; y: 37px; text: root.detail; color: AppColors.text-muted; font-size: 10px; }
    Text { x: parent.width - 143px; y: 27px; width: 90px; text: root.status; color: root.healthy ? AppColors.success : AppColors.text-muted; font-size: 10px; font-weight: 650; horizontal-alignment: right; }
    ChevronButton { x: parent.width - 50px; y: 20px; open: root.open; activated => { root.activated(); } }
    TouchArea { x: 0px; y: 0px; width: parent.width - 50px; height: parent.height; mouse-cursor: pointer; clicked => { root.activated(); } }
}

component ApiKeyField inherits Rectangle {
    in-out property <string> value;
    in property <bool> reveal;
    in property <bool> error;
    in property <string> accessible-name;
    callback toggle-reveal();
    forward-focus: field-input;
    height: 42px;
    border-radius: 8px;
    border-width: 1px;
    border-color: root.error ? AppColors.danger : field-input.has-focus ? AppColors.brand : AppColors.border;
    background: AppColors.sidebar;
    clip: true;

    ContextMenuArea {
        x: 15px;
        width: parent.width - 55px;

        Menu {
            MenuItem { title: @tr("common.cut" => "Cut"); activated => { field-input.cut(); } }
            MenuItem { title: @tr("common.copy" => "Copy"); activated => { field-input.copy(); } }
            MenuItem { title: @tr("common.paste" => "Paste"); activated => { field-input.paste(); } }
            MenuItem { title: @tr("common.select-all" => "Select All"); activated => { field-input.select-all(); } }
        }

        field-input := TextInput {
            text <=> root.value;
            input-type: root.reveal ? InputType.text : InputType.password;
            accessible-label: root.accessible-name;
            accessible-value: root.value.is-empty ? "" : @tr("common.value-entered" => "Entered");
            color: AppColors.text;
            font-size: 12px;
            vertical-alignment: center;
            key-pressed(event) => {
                if event.modifiers.control && (event.text == "v" || event.text == "V") {
                    self.paste();
                    return accept;
                }
                return reject;
            }
        }
    }
    Image { x: parent.width - 27px; y: 13px; width: 16px; height: 16px; source: @image-url("../../icons/lucide/eye.svg"); colorize: AppColors.text-muted; }
    TouchArea { x: parent.width - 40px; width: 40px; mouse-cursor: pointer; clicked => { root.toggle-reveal(); } }
}

export component ModelConsentDialog inherits Rectangle {
    in property <string> target;
    in-out property <bool> consent-checked;
    callback cancelled();
    callback confirmed();
    background: AppColors.scrim;
    TouchArea { mouse-cursor: default; clicked => { } }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 540px;
        height: 340px;
        border-radius: 14px;
        background: AppColors.surface;
        drop-shadow-blur: 32px;
        drop-shadow-offset-y: 12px;
        drop-shadow-color: AppColors.shadow;

        Rectangle { x: 30px; y: 29px; width: 40px; height: 40px; border-radius: 10px; background: AppColors.brand-soft; Image { x: 10px; y: 10px; width: 20px; height: 20px; source: @image-url("../../icons/lucide/sparkles.svg"); colorize: AppColors.brand; } }
        Text { x: 86px; y: 26px; text: @tr("models.polishing.consent.title" => "Enable text polishing?"); color: AppColors.ink; font-size: 20px; font-weight: 700; }
        Text { x: 86px; y: 56px; text: @tr("models.polishing.consent.intro" => "Before enabling it, review what text will be sent."); color: AppColors.text-muted; font-size: 11px; }
        Rectangle {
            x: 492px; y: 13px; width: 28px; height: 28px; background: transparent;
            Image { x: 5px; y: 5px; width: 18px; height: 18px; source: @image-url("../../icons/lucide/x.svg"); colorize: AppColors.text-muted; }
            TouchArea { mouse-cursor: pointer; clicked => { root.cancelled(); } }
        }
        Text { x: 30px; y: 97px; width: parent.width - 60px; text: @tr("models.polishing.consent.sent-content" => "Saymore sends the current transcript for polishing and may send a short local correction fragment to judge dictionary candidates."); color: AppColors.text; font-size: 12px; wrap: word-wrap; }
        Rectangle {
            x: 30px; y: 130px; width: 480px; height: 64px; border-radius: 8px; background: AppColors.sidebar;
            Text { x: 16px; y: 10px; text: @tr("models.polishing.consent.destination" => "Data destination"); color: AppColors.text-muted; font-size: 9px; font-weight: 600; }
            Text { x: 16px; y: 31px; text: root.target; color: AppColors.ink; font-size: 11px; font-weight: 600; }
        }
        Text { x: 30px; y: 212px; width: parent.width - 60px; text: @tr("models.polishing.consent.dictionary-excluded" => "Confirmed dictionary entries and complete input fields are not sent."); color: AppColors.text-muted; font-size: 10px; }
        Rectangle {
            x: 30px; y: 244px; width: 18px; height: 18px; border-radius: 4px; border-width: 1px; border-color: AppColors.chart-neutral; background: root.consent-checked ? AppColors.brand : AppColors.surface;
            if root.consent-checked: Image { x: 2px; y: 2px; width: 14px; height: 14px; source: @image-url("../../icons/lucide/check.svg"); colorize: AppColors.on-brand; }
            TouchArea { mouse-cursor: pointer; clicked => { root.consent-checked = !root.consent-checked; } }
        }
        Text { x: 60px; y: 244px; text: @tr("models.polishing.consent.accept" => "I understand and agree to send the content described above"); color: AppColors.ink; font-size: 11px; font-weight: 500; }
        ModelActionButton { x: 264px; y: 284px; label: @tr("common.cancel" => "Cancel"); primary: false; activated => { root.cancelled(); } }
        ModelActionButton {
            x: 384px;
            y: 284px;
            width: 126px;
            label: @tr("models.polishing.consent.confirm-and-test" => "Confirm and test");
            primary: true;
            enabled: root.consent-checked;
            activated => { root.confirmed(); }
        }
    }
}

export component ModelsPage inherits Rectangle {
    in property <bool> focus-asr-config: false;
    in-out property <string> asr-api-key;
    in-out property <string> asr-model: "volc.seedasr.sauc.duration";
    in-out property <AsrProvider> asr-provider: AsrProvider.volcengine;
    in-out property <string> custom-asr-api-key;
    in-out property <string> custom-asr-base-url;
    in-out property <string> custom-asr-model;
    in property <bool> custom-asr-configured;
    in property <bool> asr-configured;
    in property <bool> asr-config-error;
    in-out property <bool> asr-draft-error: false;
    in property <string> asr-config-status;
    in-out property <bool> asr-testing: false;
    in-out property <bool> asr-pending-test: false;
    in-out property <bool> asr-config-dirty: false;
    in-out property <bool> llm-enabled;
    in-out property <LlmProvider> llm-provider: LlmProvider.sensenova;
    in-out property <string> sensenova-api-key;
    in-out property <string> deepseek-api-key;
    in property <bool> sensenova-configured;
    in property <bool> deepseek-configured;
    in-out property <string> sensenova-model;
    in-out property <string> deepseek-model;
    in-out property <string> custom-llm-api-key;
    in-out property <string> custom-llm-base-url;
    in-out property <string> custom-llm-model;
    in property <bool> custom-llm-configured;
    in property <string> llm-provider-target;
    in property <bool> llm-provider-local;
    in property <string> llm-config-status;
    in-out property <bool> llm-config-dirty: false;
    in-out property <bool> llm-testing: false;
    in-out property <bool> llm-draft-error: false;
    in-out property <bool> llm-confirmation-visible: false;
    in-out property <int> active-tab: 0;
    in-out property <[string]> available-models;
    in-out property <bool> model-discovery-loading: false;
    in-out property <bool> model-discovery-error: false;
    in-out property <string> model-discovery-status;
    callback save-asr-config(AsrProvider, string, string, string);
    callback select-asr-provider(AsrProvider);
    callback delete-asr-config();
    callback request-llm-enable();
    callback set-llm-enabled(bool, string);
    callback save-llm-config(LlmProvider, string, string, string);
    callback select-llm-provider(LlmProvider);
    callback refresh-models();
    callback request-asr-test();
    callback open-key-page();

    private property <bool> service-menu-open: false;
    private property <bool> model-menu-open: false;
    private property <bool> advanced-visible: false;
    private property <bool> api-key-visible: false;
    private property <bool> manual-model: false;
    private property <bool> first-service-selected: root.active-tab == 0 ? root.asr-provider == AsrProvider.volcengine : root.llm-provider == LlmProvider.sensenova;
    private property <bool> second-service-selected: root.active-tab == 0 ? root.asr-provider == AsrProvider.custom : root.llm-provider == LlmProvider.deepseek;
    private property <bool> third-service-selected: root.active-tab == 1 && root.llm-provider == LlmProvider.custom;
    private property <bool> manual-model-selected: root.manual-model;
    private property <string> asr-model-label: root.asr-model == "volc.bigasr.sauc.duration" ? @tr("models.volcengine.model-v1" => "Doubao Streaming Speech Recognition 1.0") : @tr("models.volcengine.model-v2" => "Doubao Streaming Speech Recognition 2.0");
    private property <string> active-api-key: root.active-tab == 0 ? root.asr-provider == AsrProvider.custom ? root.custom-asr-api-key : root.asr-api-key : root.llm-provider == LlmProvider.custom ? root.custom-llm-api-key : root.llm-provider == LlmProvider.deepseek ? root.deepseek-api-key : root.sensenova-api-key;
    private property <string> active-base-url: root.active-tab == 0 ? root.asr-provider == AsrProvider.custom ? root.custom-asr-base-url : "https://openspeech.bytedance.com" : root.llm-provider == LlmProvider.custom ? root.custom-llm-base-url : root.llm-provider == LlmProvider.deepseek ? "https://api.deepseek.com" : "https://token.sensenova.cn/v1";
    private property <string> service-name: root.active-tab == 0 ? root.asr-provider == AsrProvider.custom ? @tr("models.provider.custom-compatible" => "Custom compatible API") : @tr("models.provider.volcengine" => "Volcengine") : root.llm-provider == LlmProvider.custom ? @tr("models.provider.custom-compatible" => "Custom compatible API") : root.llm-provider == LlmProvider.deepseek ? "DeepSeek" : "SenseNova";
    private property <string> model-name: root.active-tab == 0 ? root.asr-provider == AsrProvider.custom ? root.custom-asr-model : root.asr-model : root.llm-provider == LlmProvider.custom ? root.custom-llm-model : root.llm-provider == LlmProvider.deepseek ? root.deepseek-model : root.sensenova-model;
    private property <string> configured-model-name: root.active-tab == 0 ? root.asr-provider == AsrProvider.custom ? root.custom-asr-configured ? root.custom-asr-model : "" : root.asr-configured ? root.asr-model-label : "" : root.llm-provider == LlmProvider.custom ? root.custom-llm-configured ? root.custom-llm-model : "" : root.llm-provider == LlmProvider.deepseek ? root.deepseek-configured ? root.deepseek-model : "" : root.sensenova-configured ? root.sensenova-model : "";
    private property <string> first-service-model: root.active-tab == 0 ? root.asr-api-key.is-empty ? "" : root.asr-model-label : root.sensenova-configured ? root.sensenova-model : "";
    private property <string> second-service-model: root.active-tab == 0 ? root.custom-asr-configured ? root.custom-asr-model : "" : root.deepseek-configured ? root.deepseek-model : "";
    private property <string> third-service-model: root.custom-llm-configured ? root.custom-llm-model : "";
    private property <bool> active-config-dirty: root.active-tab == 0 ? root.asr-config-dirty : root.llm-config-dirty;
    private property <bool> active-testing: root.active-tab == 0 ? root.asr-testing : root.llm-testing;
    private property <bool> active-draft-error: root.active-tab == 0 ? root.asr-draft-error : root.llm-draft-error;
    private property <bool> active-config-saved: !root.configured-model-name.is-empty && !root.active-config-dirty;
    private property <bool> custom-llm-ready: root.llm-provider == LlmProvider.custom && !root.custom-llm-base-url.is-empty && !root.custom-llm-model.is-empty;
    private property <bool> configuration-ready: root.custom-llm-ready || !root.active-api-key.is-empty;
    private property <bool> model-fetch-enabled: (root.active-tab == 0 && root.asr-provider == AsrProvider.volcengine) || (root.active-tab == 1 && root.llm-provider == LlmProvider.custom ? !root.custom-llm-base-url.is-empty : !root.active-api-key.is-empty);
    private property <bool> service-healthy: root.active-tab == 0 ? root.asr-configured && !root.asr-config-error && !root.asr-pending-test && !root.asr-testing : root.llm-enabled;
    private property <string> service-status: root.active-testing ? @tr("models.status.testing" => "●  Testing") : root.active-config-dirty ? root.active-draft-error ? @tr("models.status.connection-failed" => "●  Connection issue") : @tr("models.status.unsaved" => "●  Unsaved changes") : root.active-tab == 0 ? root.asr-config-error ? @tr("models.status.connection-failed" => "●  Connection issue") : root.asr-pending-test ? @tr("models.status.awaiting-connection-test" => "●  Awaiting connection test") : root.service-healthy ? @tr("models.status.connected" => "●  Connected") : @tr("models.status.not-configured" => "●  Not configured") : root.service-healthy ? @tr("models.status.connected" => "●  Connected") : root.llm-config-status;
    private property <length> config-height: root.advanced-visible ? 270px : 228px;
    private property <length> action-y: root.advanced-visible ? 560px : 525px;
    forward-focus: asr-field;
    init => { if root.focus-asr-config { root.focus(); } }
    changed model-discovery-error => { if root.model-discovery-error { root.model-menu-open = true; } }
    changed asr-api-key => { root.asr-config-dirty = true; root.asr-draft-error = false; }
    changed asr-model => { root.asr-config-dirty = true; root.asr-draft-error = false; }
    changed custom-asr-api-key => { root.asr-config-dirty = true; root.asr-draft-error = false; }
    changed custom-asr-base-url => { root.asr-config-dirty = true; root.asr-draft-error = false; }
    changed custom-asr-model => { root.asr-config-dirty = true; root.asr-draft-error = false; }
    changed sensenova-api-key => { root.llm-config-dirty = true; root.llm-draft-error = false; }
    changed sensenova-model => { root.llm-config-dirty = true; root.llm-draft-error = false; }
    changed deepseek-api-key => { root.llm-config-dirty = true; root.llm-draft-error = false; }
    changed deepseek-model => { root.llm-config-dirty = true; root.llm-draft-error = false; }
    changed custom-llm-api-key => { root.llm-config-dirty = true; root.llm-draft-error = false; }
    changed custom-llm-base-url => { root.llm-config-dirty = true; root.llm-draft-error = false; }
    changed custom-llm-model => { root.llm-config-dirty = true; root.llm-draft-error = false; }
    Timer { interval: 5s; running: root.api-key-visible; triggered => { root.api-key-visible = false; } }
    background: transparent;

    Text { x: 0px; y: 44px; text: @tr("models.title" => "Models"); color: AppColors.ink; font-size: 27px; font-weight: 700; }
    transcription-tab := ModelTab { x: 0px; y: 89px; label: @tr("models.tab.speech-recognition" => "Transcription"); selected: root.active-tab == 0; activated => { root.active-tab = 0; root.service-menu-open = false; root.model-menu-open = false; root.api-key-visible = false; root.manual-model = false; } }
    ModelTab { x: transcription-tab.x + transcription-tab.width + 24px; y: 89px; label: @tr("models.tab.text-polishing" => "Polishing"); selected: root.active-tab == 1; activated => { root.active-tab = 1; root.service-menu-open = false; root.model-menu-open = false; root.api-key-visible = false; root.manual-model = false; } }
    Rectangle { x: 0px; y: 120px; width: parent.width - 1px; height: 1px; background: AppColors.border; }

    Text { x: 0px; y: 140px; text: root.active-tab == 0 ? @tr("models.speech-service" => "Speech recognition service") : @tr("models.polishing-service" => "Text polishing service"); color: AppColors.text; font-size: 14px; font-weight: 650; }
    if root.active-tab == 1: LlmEnableSwitch {
        x: parent.width - 46px;
        y: 140px;
        checked: root.llm-enabled;
        activated => {
            if root.llm-enabled {
                root.set-llm-enabled(false, root.llm-provider-target);
            } else {
                root.request-llm-enable();
            }
        }
    }
    ServiceCard {
        x: 0px; y: 166px; width: parent.width - 1px;
        icon: root.active-tab == 0 ? @image-url("../../icons/lucide/audio-lines.svg") : @image-url("../../icons/lucide/sparkles.svg");
        name: root.service-name;
        detail: root.active-tab == 0 && !root.asr-configured ? @tr("models.api-key.not-configured" => "API key not configured") : root.configured-model-name.is-empty ? "" : root.active-tab == 0 && root.asr-pending-test ? @tr("models.model.saved-not-enabled" => "{} · Connection not tested", root.configured-model-name) : @tr("models.model.current-default" => "{} · Current default", root.configured-model-name);
        status: root.service-status;
        healthy: root.service-healthy;
        open: root.service-menu-open;
        activated => { root.service-menu-open = !root.service-menu-open; root.model-menu-open = false; }
    }

    Text { x: 0px; y: 258px; text: @tr("models.connection-settings" => "Connection settings"); color: AppColors.text; font-size: 14px; font-weight: 650; }
    Rectangle {
        x: 0px; y: 283px; width: parent.width - 1px; height: root.config-height; border-radius: 12px; background: AppColors.surface;

        Text { x: 18px; y: 17px; text: root.active-tab == 0 && root.asr-provider == AsrProvider.custom ? "Access Token / API Key" : "API Key"; color: AppColors.text; font-size: 11px; font-weight: 600; }
        // Keep the secondary actions on one shared column so their labels align.
        if !(root.active-tab == 0 && root.asr-provider == AsrProvider.custom) && !(root.active-tab == 1 && root.llm-provider == LlmProvider.custom): Rectangle {
            x: parent.width - 108px; y: 8px; width: 86px; height: 25px; background: transparent;
            accessible-role: button;
            accessible-label: @tr("models.get-api-key" => "Get API key");
            accessible-action-default => { root.open-key-page(); }
            Text { x: 0px; width: 62px; text: @tr("models.get-api-key" => "Get API key"); color: AppColors.brand; font-size: 10px; font-weight: 600; horizontal-alignment: left; vertical-alignment: center; }
            Text { x: parent.width - 20px; width: 14px; text: "↗"; color: AppColors.brand; font-size: 10px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
            TouchArea { mouse-cursor: pointer; clicked => { root.open-key-page(); } }
        }

        asr-field := ApiKeyField {
            visible: root.active-tab == 0 && root.asr-provider == AsrProvider.volcengine;
            x: 18px; y: 39px; width: parent.width - 36px; height: 42px;
            value <=> root.asr-api-key; reveal: root.api-key-visible; error: root.asr-draft-error || root.asr-config-error; accessible-name: @tr("models.volcengine-api-key" => "Volcengine API key");
            toggle-reveal => { root.api-key-visible = !root.api-key-visible; }
        }
        if root.active-tab == 0 && root.asr-provider == AsrProvider.custom: ApiKeyField {
            x: 18px; y: 39px; width: parent.width - 36px; height: 42px;
            value <=> root.custom-asr-api-key; reveal: root.api-key-visible; error: root.asr-draft-error || root.asr-config-error; accessible-name: @tr("models.custom-speech-api-key" => "Custom speech recognition API key");
            toggle-reveal => { root.api-key-visible = !root.api-key-visible; }
        }
        if root.active-tab == 1 && root.llm-provider == LlmProvider.sensenova: ApiKeyField {
            x: 18px; y: 39px; width: parent.width - 36px; value <=> root.sensenova-api-key; reveal: root.api-key-visible; error: false; accessible-name: @tr("models.sensenova-api-key" => "SenseNova API key");
            toggle-reveal => { root.api-key-visible = !root.api-key-visible; }
        }
        if root.active-tab == 1 && root.llm-provider == LlmProvider.deepseek: ApiKeyField {
            x: 18px; y: 39px; width: parent.width - 36px; value <=> root.deepseek-api-key; reveal: root.api-key-visible; error: false; accessible-name: "DeepSeek API Key";
            toggle-reveal => { root.api-key-visible = !root.api-key-visible; }
        }
        if root.active-tab == 1 && root.llm-provider == LlmProvider.custom: ApiKeyField {
            x: 18px; y: 39px; width: parent.width - 36px; value <=> root.custom-llm-api-key; reveal: root.api-key-visible; error: false; accessible-name: @tr("models.custom-llm-api-key" => "Custom polishing API key (optional for local services)");
            toggle-reveal => { root.api-key-visible = !root.api-key-visible; }
        }

        Text { x: 18px; y: 95px; text: @tr("models.model-field" => "Model"); color: AppColors.text; font-size: 11px; font-weight: 600; }
        Text { x: 56px; y: 96px; width: parent.width - 164px; text: root.model-discovery-status; color: AppColors.text-muted; font-size: 9px; overflow: elide; }
        Rectangle {
            x: parent.width - 108px; y: 88px; width: 86px; height: 25px; border-radius: 6px; background: fetch-area.has-hover ? AppColors.surface-subtle : transparent;
            opacity: !root.model-fetch-enabled || root.model-discovery-loading ? 0.55 : 1;
            accessible-role: button; accessible-label: root.model-discovery-loading ? @tr("models.fetch.loading-accessible" => "Fetching models") : @tr("models.fetch.action" => "Fetch models"); accessible-enabled: root.model-fetch-enabled && !root.model-discovery-loading;
            Text { x: 0px; width: 62px; text: root.model-discovery-loading ? @tr("models.fetch.loading" => "Fetching…") : @tr("models.fetch.action" => "Fetch models"); color: AppColors.brand; font-size: 10px; font-weight: 600; horizontal-alignment: left; vertical-alignment: center; }
            Image { visible: !root.model-discovery-loading; x: parent.width - 20px; y: 7px; width: 12px; height: 12px; source: @image-url("../../icons/lucide/download.svg"); colorize: AppColors.brand; }
            fetch-area := TouchArea { enabled: root.model-fetch-enabled && !root.model-discovery-loading; mouse-cursor: self.enabled ? pointer : default; clicked => { root.model-menu-open = false; root.refresh-models(); } }
        }
        Rectangle {
            x: 18px; y: 116px; width: parent.width - 36px; height: 42px; border-radius: 8px; background: AppColors.sidebar;
            if root.active-tab == 0 && root.asr-provider == AsrProvider.custom && root.manual-model && root.custom-asr-model.is-empty: Text { x: 15px; width: parent.width - 50px; text: @tr("models.model-id.placeholder" => "Enter the model ID from your provider"); color: AppColors.text-muted; font-size: 12px; vertical-alignment: center; }
            if root.active-tab == 0 && root.asr-provider == AsrProvider.custom && root.manual-model: TextInput { x: 15px; width: parent.width - 50px; text <=> root.custom-asr-model; color: AppColors.text; font-size: 12px; vertical-alignment: center; }
            if root.active-tab == 1 && root.llm-provider == LlmProvider.sensenova && root.manual-model: TextInput { x: 15px; width: parent.width - 50px; text <=> root.sensenova-model; color: AppColors.text; font-size: 12px; vertical-alignment: center; }
            if root.active-tab == 1 && root.llm-provider == LlmProvider.deepseek && root.manual-model: TextInput { x: 15px; width: parent.width - 50px; text <=> root.deepseek-model; color: AppColors.text; font-size: 12px; vertical-alignment: center; }
            if root.active-tab == 1 && root.llm-provider == LlmProvider.custom && root.manual-model: TextInput { x: 15px; width: parent.width - 50px; text <=> root.custom-llm-model; color: AppColors.text; font-size: 12px; vertical-alignment: center; }
            if !root.manual-model: Text { x: 15px; width: parent.width - 50px; text: root.active-tab == 0 && root.asr-provider == AsrProvider.volcengine ? root.asr-model-label : root.model-name; color: AppColors.text; font-size: 12px; vertical-alignment: center; overflow: elide; }
            if !root.manual-model: TouchArea { mouse-cursor: pointer; clicked => { root.model-menu-open = !root.model-menu-open; root.service-menu-open = false; } }
            ChevronButton { x: parent.width - 32px; y: (parent.height - 32px) / 2; open: root.model-menu-open; activated => { root.model-menu-open = !root.model-menu-open; root.service-menu-open = false; } }
        }

        Rectangle {
            x: 18px; y: 166px; width: parent.width - 36px; height: 34px; background: transparent;
            accessible-role: button; accessible-label: @tr("models.advanced-settings" => "Advanced settings");
            advanced-title := Text { x: 15px; text: @tr("models.advanced-settings" => "Advanced settings"); color: AppColors.text; font-size: 11px; font-weight: 600; vertical-alignment: center; }
            if !root.advanced-visible: Text { x: advanced-title.x + advanced-title.preferred-width + 14px; width: parent.width - self.x - 34px; text: @tr("models.base-url" => "Service URL"); color: AppColors.text-muted; font-size: 10px; vertical-alignment: center; overflow: elide; }
            Image { x: parent.width - 24px; y: 10px; width: 14px; height: 14px; source: root.advanced-visible ? @image-url("../../icons/lucide/chevron-up.svg") : @image-url("../../icons/lucide/chevron-right.svg"); colorize: AppColors.text-muted; }
            TouchArea { mouse-cursor: pointer; clicked => { root.advanced-visible = !root.advanced-visible; root.model-menu-open = false; } }
        }

        if root.advanced-visible: Text { x: 18px; y: 209px; text: @tr("models.base-url" => "Service URL"); color: AppColors.text; font-size: 11px; font-weight: 600; }
        if root.advanced-visible: Rectangle {
            x: 18px; y: 228px; width: parent.width - 36px; height: 36px; border-radius: 8px; background: AppColors.sidebar;
            if ((root.active-tab == 0 && root.asr-provider == AsrProvider.custom && root.custom-asr-base-url.is-empty) || (root.active-tab == 1 && root.llm-provider == LlmProvider.custom && root.custom-llm-base-url.is-empty)): Text { x: 15px; width: parent.width - 30px; text: "https://api.example.com/v1"; color: AppColors.text-muted; font-size: 11px; vertical-alignment: center; }
            if root.active-tab == 0 && root.asr-provider == AsrProvider.custom: TextInput { x: 15px; width: parent.width - 30px; text <=> root.custom-asr-base-url; color: AppColors.text; font-size: 11px; vertical-alignment: center; }
            if root.active-tab == 1 && root.llm-provider == LlmProvider.custom: TextInput { x: 15px; width: parent.width - 30px; text <=> root.custom-llm-base-url; color: AppColors.text; font-size: 11px; vertical-alignment: center; }
            if !((root.active-tab == 0 && root.asr-provider == AsrProvider.custom) || (root.active-tab == 1 && root.llm-provider == LlmProvider.custom)): Text { x: 15px; text: root.active-base-url; color: AppColors.text; font-size: 11px; vertical-alignment: center; }
        }
    }

    ModelActionButton {
        x: 0px;
        y: root.action-y;
        label: root.active-testing ? @tr("models.save.testing" => "Testing…") : root.active-config-saved ? @tr("common.saved" => "Saved") : @tr("models.save-configuration" => "Save configuration");
        primary: !root.active-config-saved;
        completed: root.active-config-saved;
        enabled: root.configuration-ready && root.active-config-dirty && !root.active-testing;
        activated => {
            if root.active-tab == 0 { root.save-asr-config(root.asr-provider, root.active-api-key, root.active-base-url, root.model-name); }
            else { root.save-llm-config(root.llm-provider, root.active-api-key, root.active-base-url, root.model-name); }
        }
    }
    if root.active-config-saved: ModelActionButton {
        x: 120px; y: root.action-y; label: root.active-testing ? @tr("models.test.testing" => "Testing…") : root.active-draft-error ? @tr("models.test.retry" => "Test again") : @tr("models.test.action" => "Test connection"); primary: root.active-draft-error; enabled: root.configuration-ready && !root.active-testing;
        activated => { if root.active-tab == 0 { root.request-asr-test(); } else { root.request-llm-enable(); } }
    }
    Text { x: parent.width - 270px; y: root.action-y + 13px; width: 269px; text: root.api-key-visible ? @tr("models.api-key.auto-hide" => "Hides automatically in 5 seconds") : root.active-testing ? @tr("models.test.testing-connection" => "Testing connection") : root.active-draft-error ? root.active-tab == 0 ? root.asr-config-status : root.llm-config-status : root.active-config-dirty ? @tr("models.status.unsaved.plain" => "Unsaved changes") : root.service-status; color: root.active-draft-error ? AppColors.danger : root.active-config-dirty ? AppColors.warning : root.service-healthy ? AppColors.success : AppColors.text-muted; font-size: 10px; font-weight: 650; horizontal-alignment: right; overflow: elide; }

    if root.service-menu-open || root.model-menu-open: Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: transparent;
        z: 30;
        TouchArea { mouse-cursor: default; clicked => { root.service-menu-open = false; root.model-menu-open = false; } }
    }

    if root.service-menu-open: Rectangle {
        x: 0px; y: 242px; width: parent.width - 1px; height: root.active-tab == 1 ? 176px : 124px; border-radius: 12px; background: AppColors.surface; z: 40; drop-shadow-blur: 18px; drop-shadow-offset-y: 6px; drop-shadow-color: AppColors.shadow;
        Rectangle {
            x: 12px; y: 12px; width: parent.width - 24px; height: 48px; border-radius: 8px; background: root.first-service-selected ? AppColors.sidebar : AppColors.surface;
            Image { x: 16px; y: 14px; width: 18px; height: 18px; source: root.active-tab == 0 ? @image-url("../../icons/lucide/audio-lines.svg") : @image-url("../../icons/lucide/sparkles.svg"); colorize: root.first-service-selected ? AppColors.ink : AppColors.text-muted; }
            Text { x: 46px; y: root.first-service-model.is-empty ? 16px : 5px; text: root.active-tab == 0 ? @tr("models.provider.volcengine" => "Volcengine") : "SenseNova"; color: AppColors.ink; font-size: 12px; font-weight: 650; }
            if !root.first-service-model.is-empty: Text { x: 46px; y: 27px; text: root.first-service-model; color: AppColors.text-muted; font-size: 9px; }
            if root.first-service-selected: Image { x: parent.width - 29px; y: 17px; width: 14px; height: 14px; source: @image-url("../../icons/lucide/check.svg"); colorize: AppColors.success; }
            TouchArea { mouse-cursor: pointer; clicked => { if root.active-tab == 0 { root.asr-provider = AsrProvider.volcengine; root.select-asr-provider(root.asr-provider); } else { root.llm-provider = LlmProvider.sensenova; root.select-llm-provider(root.llm-provider); } root.api-key-visible = false; root.manual-model = false; root.service-menu-open = false; } }
        }
        if root.active-tab == 1: Rectangle {
            x: 12px; y: 116px; width: parent.width - 24px; height: 48px; border-radius: 8px; background: root.third-service-selected ? AppColors.sidebar : AppColors.surface;
            Image { x: 16px; y: 14px; width: 18px; height: 18px; source: @image-url("../../icons/lucide/settings.svg"); colorize: root.third-service-selected ? AppColors.ink : AppColors.text-muted; }
            Text { x: 46px; y: root.third-service-model.is-empty ? 16px : 5px; text: @tr("models.provider.custom-compatible" => "Custom compatible API"); color: AppColors.ink; font-size: 12px; font-weight: 650; }
            if !root.third-service-model.is-empty: Text { x: 46px; y: 27px; width: parent.width - 90px; text: root.third-service-model; color: AppColors.text-muted; font-size: 9px; overflow: elide; }
            if root.third-service-selected: Image { x: parent.width - 29px; y: 17px; width: 14px; height: 14px; source: @image-url("../../icons/lucide/check.svg"); colorize: AppColors.success; }
            TouchArea { mouse-cursor: pointer; clicked => { root.llm-provider = LlmProvider.custom; root.select-llm-provider(root.llm-provider); root.api-key-visible = false; root.manual-model = root.custom-llm-model.is-empty; root.advanced-visible = true; root.service-menu-open = false; } }
        }
        Rectangle {
            x: 12px; y: 64px; width: parent.width - 24px; height: 48px; border-radius: 8px; background: root.second-service-selected ? AppColors.sidebar : AppColors.surface;
            Image { x: 16px; y: 14px; width: 18px; height: 18px; source: root.active-tab == 0 ? @image-url("../../icons/lucide/audio-lines.svg") : @image-url("../../icons/lucide/sparkles.svg"); colorize: root.second-service-selected ? AppColors.ink : AppColors.text-muted; }
            Text { x: 46px; y: root.second-service-model.is-empty ? 16px : 5px; text: root.active-tab == 0 ? @tr("models.provider.custom-compatible" => "Custom compatible API") : "DeepSeek"; color: AppColors.ink; font-size: 12px; font-weight: 650; }
            if !root.second-service-model.is-empty: Text { x: 46px; y: 27px; text: root.second-service-model; color: AppColors.text-muted; font-size: 9px; }
            if root.second-service-selected: Image { x: parent.width - 29px; y: 17px; width: 14px; height: 14px; source: @image-url("../../icons/lucide/check.svg"); colorize: AppColors.success; }
            TouchArea { mouse-cursor: pointer; clicked => { if root.active-tab == 0 { root.asr-provider = AsrProvider.custom; root.select-asr-provider(root.asr-provider); root.manual-model = root.custom-asr-model.is-empty; root.advanced-visible = true; } else { root.llm-provider = LlmProvider.deepseek; root.select-llm-provider(root.llm-provider); root.manual-model = false; } root.api-key-visible = false; root.service-menu-open = false; } }
        }
    }

    if root.model-menu-open: Rectangle {
        x: 18px; y: 443px; width: parent.width - 37px; height: 100px; border-radius: 10px; background: AppColors.surface; z: 40; drop-shadow-blur: 18px; drop-shadow-offset-y: 6px; drop-shadow-color: AppColors.shadow;
        ScrollView {
            x: 10px; y: 10px; width: parent.width - 20px; height: parent.height - 20px;
            vertical-scrollbar-policy: ScrollBarPolicy.always-off;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
            VerticalLayout {
                spacing: 8px;
                if root.model-discovery-error: Rectangle {
                    height: 36px; border-radius: 7px; background: AppColors.danger-soft;
                    Text { x: 14px; width: parent.width - 48px; text: @tr("models.list.load-failed" => "Could not load models. Check your network connection."); color: AppColors.danger; font-size: 11px; vertical-alignment: center; }
                    Text { x: parent.width - 27px; text: "↻"; color: AppColors.danger; font-size: 14px; vertical-alignment: center; }
                    TouchArea { mouse-cursor: pointer; clicked => { root.refresh-models(); } }
                }
                if root.available-models.length == 0 && !root.model-discovery-error: Rectangle {
                    height: 36px; border-radius: 7px; background: AppColors.surface;
                    Text { x: 14px; text: root.model-discovery-status.is-empty ? @tr("models.list.not-fetched" => "Models have not been fetched yet") : root.model-discovery-status; color: AppColors.text-muted; font-size: 11px; vertical-alignment: center; }
                }
                for model-id in root.available-models: Rectangle {
                    height: 36px; border-radius: 7px; background: !root.manual-model && model-id == root.model-name ? AppColors.sidebar : AppColors.surface;
                    Text { x: 14px; width: parent.width - 48px; text: root.active-tab == 0 && root.asr-provider == AsrProvider.volcengine ? model-id == "volc.bigasr.sauc.duration" ? @tr("models.volcengine.model-v1" => "Doubao Streaming Speech Recognition 1.0") : @tr("models.volcengine.model-v2" => "Doubao Streaming Speech Recognition 2.0") : model-id; color: AppColors.text; font-size: 11px; vertical-alignment: center; overflow: elide; }
                    if !root.manual-model && model-id == root.model-name: Image { x: parent.width - 24px; y: 11px; width: 14px; height: 14px; source: @image-url("../../icons/lucide/check.svg"); colorize: AppColors.success; }
                    TouchArea { mouse-cursor: pointer; clicked => { root.manual-model = false; if root.active-tab == 0 && root.asr-provider == AsrProvider.custom { root.custom-asr-model = model-id; } else if root.active-tab == 0 { root.asr-model = model-id; } else if root.llm-provider == LlmProvider.custom { root.custom-llm-model = model-id; } else if root.llm-provider == LlmProvider.deepseek { root.deepseek-model = model-id; } else { root.sensenova-model = model-id; } root.model-menu-open = false; } }
                }
                if !(root.active-tab == 0 && root.asr-provider == AsrProvider.volcengine): Rectangle {
                    height: 36px; border-radius: 7px; background: root.manual-model-selected ? AppColors.sidebar : AppColors.surface;
                    Text { x: 14px; text: @tr("models.model.manual-entry" => "Enter model name manually"); color: AppColors.text; font-size: 11px; vertical-alignment: center; }
                    if root.manual-model-selected: Image { x: parent.width - 24px; y: 11px; width: 14px; height: 14px; source: @image-url("../../icons/lucide/check.svg"); colorize: AppColors.success; }
                    TouchArea { mouse-cursor: pointer; clicked => { root.manual-model = true; if root.active-tab == 0 && root.asr-provider == AsrProvider.custom { root.custom-asr-model = ""; } else if root.active-tab == 0 { root.asr-model = ""; } else if root.llm-provider == LlmProvider.custom { root.custom-llm-model = ""; } else if root.llm-provider == LlmProvider.deepseek { root.deepseek-model = ""; } else { root.sensenova-model = ""; } root.model-menu-open = false; } }
                }
            }
        }
    }
}
