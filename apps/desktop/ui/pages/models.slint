import { LlmProvider } from "../components.slint";
import { AppColors } from "../color-system.slint";
import { ScrollView } from "std-widgets.slint";

component ModelTab inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    callback activated();
    width: 56px;
    height: 32px;
    background: transparent;
    accessible-role: button;
    accessible-label: root.label;
    accessible-action-default => { root.activated(); }

    Text {
        y: 0px;
        text: root.label;
        color: root.selected ? AppColors.ink : AppColors.text-muted;
        font-size: 14px;
        font-weight: root.selected ? 700 : 600;
    }
    if root.selected: Rectangle {
        y: 28px;
        width: 56px;
        height: 3px;
        border-radius: 2px;
        background: AppColors.brand;
    }
    TouchArea { mouse-cursor: pointer; clicked => { root.activated(); } }
}

component ModelActionButton inherits Rectangle {
    in property <string> label;
    in property <bool> primary;
    in property <bool> enabled: true;
    callback activated();
    width: 110px;
    height: 40px;
    border-radius: 8px;
    background: root.primary ? AppColors.brand : AppColors.surface-subtle;
    opacity: root.enabled ? 1 : 0.55;
    accessible-role: button;
    accessible-label: root.label;
    accessible-enabled: root.enabled;
    accessible-action-default => { if root.enabled { root.activated(); } }
    Text { text: root.label; color: root.primary ? #ffffff : AppColors.text; font-size: 12px; font-weight: 650; horizontal-alignment: center; vertical-alignment: center; }
    TouchArea { enabled: root.enabled; mouse-cursor: root.enabled ? pointer : default; clicked => { root.activated(); } }
}

component ChevronButton inherits Rectangle {
    in property <bool> open;
    callback activated();
    width: 32px;
    height: 32px;
    background: transparent;
    Image {
        x: 9px;
        y: 9px;
        width: 14px;
        height: 14px;
        source: root.open ? @image-url("../../icons/lucide/chevron-up.svg") : @image-url("../../icons/lucide/chevron-down.svg");
        colorize: AppColors.text-muted;
    }
    TouchArea { mouse-cursor: pointer; clicked => { root.activated(); } }
}

component ServiceCard inherits Rectangle {
    in property <image> icon;
    in property <string> name;
    in property <string> detail;
    in property <string> status;
    in property <bool> healthy;
    in property <bool> open;
    callback activated();
    height: 72px;
    border-radius: 12px;
    background: AppColors.surface;

    Image { x: 18px; y: 20px; width: 20px; height: 20px; source: root.icon; colorize: AppColors.ink; }
    Text { x: 50px; y: 13px; text: root.name; color: AppColors.ink; font-size: 14px; font-weight: 650; }
    Text { x: 50px; y: 37px; text: root.detail; color: AppColors.text-muted; font-size: 10px; }
    Text { x: parent.width - 110px; y: 27px; width: 82px; text: root.status; color: root.healthy ? AppColors.success : AppColors.text-muted; font-size: 10px; font-weight: 650; horizontal-alignment: right; }
    ChevronButton { x: parent.width - 32px; y: 20px; open: root.open; activated => { root.activated(); } }
    TouchArea { x: 0px; y: 0px; width: parent.width - 32px; height: parent.height; mouse-cursor: pointer; clicked => { root.activated(); } }
}

component ApiKeyField inherits Rectangle {
    in-out property <string> value;
    in property <bool> reveal;
    in property <bool> error;
    in property <string> accessible-name;
    callback accepted(string);
    callback toggle-reveal();
    forward-focus: field-input;
    height: 42px;
    border-radius: 8px;
    border-width: field-input.has-focus || root.error ? 1px : 0px;
    border-color: root.error ? AppColors.danger : AppColors.brand;
    background: AppColors.sidebar;
    clip: true;

    field-input := TextInput {
        x: 15px;
        width: parent.width - 55px;
        text <=> root.value;
        input-type: root.reveal ? InputType.text : InputType.password;
        accessible-label: root.accessible-name;
        accessible-value: root.value.is-empty ? "" : "已填写";
        color: AppColors.text;
        font-size: 12px;
        vertical-alignment: center;
        accepted => { root.accepted(self.text); }
    }
    Image { x: parent.width - 27px; y: 13px; width: 16px; height: 16px; source: @image-url("../../icons/lucide/eye.svg"); colorize: AppColors.text-muted; }
    TouchArea { x: parent.width - 40px; width: 40px; mouse-cursor: pointer; clicked => { root.toggle-reveal(); } }
}

export component ModelConsentDialog inherits Rectangle {
    in property <string> target;
    in-out property <bool> consent-checked;
    callback cancelled();
    callback confirmed();
    background: #1f1f1c66;

    Rectangle {
        x: parent.width - 620px;
        y: (parent.height - 340px) / 2 + 5px;
        width: 540px;
        height: 340px;
        border-radius: 14px;
        background: AppColors.surface;
        drop-shadow-blur: 32px;
        drop-shadow-offset-y: 12px;
        drop-shadow-color: #1f1f1c33;

        Rectangle { x: 30px; y: 29px; width: 40px; height: 40px; border-radius: 10px; background: #f2ded6; Image { x: 10px; y: 10px; width: 20px; height: 20px; source: @image-url("../../icons/lucide/sparkles.svg"); colorize: AppColors.brand; } }
        Text { x: 86px; y: 26px; text: "启用文本润色？"; color: AppColors.ink; font-size: 20px; font-weight: 700; }
        Text { x: 86px; y: 56px; text: "首次启用前，请确认文本的发送范围。"; color: AppColors.text-muted; font-size: 11px; }
        Rectangle {
            x: 492px; y: 13px; width: 28px; height: 28px; background: transparent;
            Image { x: 5px; y: 5px; width: 18px; height: 18px; source: @image-url("../../icons/lucide/x.svg"); colorize: AppColors.text-muted; }
            TouchArea { mouse-cursor: pointer; clicked => { root.cancelled(); } }
        }
        Text { x: 30px; y: 97px; text: "Saymore 会将本次转写文本发送到所选服务完成润色。"; color: AppColors.text; font-size: 12px; }
        Rectangle {
            x: 30px; y: 130px; width: 480px; height: 64px; border-radius: 8px; background: AppColors.sidebar;
            Text { x: 16px; y: 10px; text: "数据发送目标"; color: AppColors.text-muted; font-size: 9px; font-weight: 600; }
            Text { x: 16px; y: 31px; text: root.target; color: AppColors.ink; font-size: 11px; font-weight: 600; }
        }
        Text { x: 30px; y: 212px; text: "仅发送本次转写文本，不发送个人词典条目。"; color: AppColors.text-muted; font-size: 10px; }
        Rectangle {
            x: 30px; y: 244px; width: 18px; height: 18px; border-radius: 4px; border-width: 1px; border-color: AppColors.chart-neutral; background: root.consent-checked ? AppColors.brand : AppColors.surface;
            if root.consent-checked: Image { x: 2px; y: 2px; width: 14px; height: 14px; source: @image-url("../../icons/lucide/check.svg"); colorize: #ffffff; }
            TouchArea { mouse-cursor: pointer; clicked => { root.consent-checked = !root.consent-checked; } }
        }
        Text { x: 60px; y: 244px; text: "我已了解并同意发送上述内容"; color: AppColors.ink; font-size: 11px; font-weight: 500; }
        ModelActionButton { x: 264px; y: 284px; label: "取消"; primary: false; activated => { root.cancelled(); } }
        Rectangle {
            x: 384px; y: 284px; width: 126px; height: 40px; border-radius: 8px; background: AppColors.brand;
            Text { text: "确认并测试"; color: #ffffff; font-size: 12px; font-weight: 650; horizontal-alignment: center; vertical-alignment: center; }
            TouchArea { enabled: root.consent-checked; mouse-cursor: root.consent-checked ? pointer : default; clicked => { root.confirmed(); } }
        }
    }
}

export component ModelsPage inherits Rectangle {
    in property <bool> focus-asr-config: false;
    in-out property <string> asr-api-key;
    in-out property <string> asr-model: "bigmodel_async";
    in property <bool> asr-configured;
    in property <bool> asr-config-error;
    in property <string> asr-config-status;
    in-out property <bool> asr-testing: false;
    in-out property <bool> asr-pending-test: false;
    in-out property <bool> llm-enabled;
    in-out property <LlmProvider> llm-provider: LlmProvider.sensenova;
    in-out property <string> sensenova-api-key;
    in-out property <string> deepseek-api-key;
    in property <bool> sensenova-configured;
    in property <bool> deepseek-configured;
    in-out property <string> sensenova-model;
    in-out property <string> deepseek-model;
    in property <string> llm-provider-target;
    in property <bool> llm-provider-local;
    in property <string> llm-config-status;
    in-out property <bool> llm-confirmation-visible: false;
    in-out property <int> active-tab: 0;
    in-out property <[string]> available-models;
    in-out property <bool> model-discovery-loading: false;
    in-out property <bool> model-discovery-error: false;
    in-out property <string> model-discovery-status;
    callback save-asr-config(string, string);
    callback delete-asr-config();
    callback request-llm-enable();
    callback set-llm-enabled(bool, string);
    callback save-llm-config(LlmProvider, string, string);
    callback select-llm-provider(LlmProvider);
    callback refresh-models();
    callback request-asr-test();

    private property <bool> service-menu-open: false;
    private property <bool> model-menu-open: false;
    private property <bool> advanced-visible: false;
    private property <bool> api-key-visible: false;
    private property <bool> manual-model: false;
    private property <bool> first-service-selected: root.active-tab == 0 || root.llm-provider == LlmProvider.sensenova;
    private property <bool> second-service-selected: root.active-tab == 1 && root.llm-provider == LlmProvider.deepseek;
    private property <bool> manual-model-selected: root.manual-model;
    private property <string> asr-model-label: "豆包流式语音识别模型 2.0";
    private property <string> active-api-key: root.active-tab == 0 ? root.asr-api-key : root.llm-provider == LlmProvider.deepseek ? root.deepseek-api-key : root.sensenova-api-key;
    private property <string> service-name: root.active-tab == 0 ? "火山引擎" : root.llm-provider == LlmProvider.deepseek ? "DeepSeek" : "商汤 SenseNova";
    private property <string> model-name: root.active-tab == 0 ? root.asr-model : root.llm-provider == LlmProvider.deepseek ? root.deepseek-model : root.sensenova-model;
    private property <string> configured-model-name: root.active-tab == 0 ? root.asr-configured ? root.asr-model-label : "" : root.llm-provider == LlmProvider.deepseek ? root.deepseek-configured ? root.deepseek-model : "" : root.sensenova-configured ? root.sensenova-model : "";
    private property <string> first-service-model: root.active-tab == 0 ? root.asr-configured ? root.asr-model-label : "" : root.sensenova-configured ? root.sensenova-model : "";
    private property <string> second-service-model: root.deepseek-configured ? root.deepseek-model : "";
    private property <bool> service-healthy: root.active-tab == 0 ? root.asr-configured && !root.asr-config-error && !root.asr-pending-test && !root.asr-testing : root.llm-enabled;
    private property <string> service-status: root.active-tab == 0 ? root.asr-testing ? "●  正在测试" : root.asr-config-error ? "●  连接失败" : root.asr-pending-test ? "●  已保存" : root.service-healthy ? "●  连接正常" : "●  未配置" : root.service-healthy ? "●  连接正常" : root.llm-config-status;
    private property <length> config-height: root.advanced-visible ? 270px : 228px;
    private property <length> action-y: root.advanced-visible ? 560px : 525px;
    forward-focus: asr-field;
    init => { if root.focus-asr-config { root.focus(); } }
    changed model-discovery-error => { if root.model-discovery-error { root.model-menu-open = true; } }
    Timer { interval: 5s; running: root.api-key-visible; triggered => { root.api-key-visible = false; } }
    background: transparent;

    Text { x: 0px; y: 44px; text: "模型"; color: AppColors.ink; font-size: 27px; font-weight: 700; }
    ModelTab { x: 0px; y: 89px; label: "语音识别"; selected: root.active-tab == 0; activated => { root.active-tab = 0; root.service-menu-open = false; root.model-menu-open = false; root.api-key-visible = false; root.manual-model = false; } }
    ModelTab { x: 97px; y: 89px; label: "文本润色"; selected: root.active-tab == 1; activated => { root.active-tab = 1; root.service-menu-open = false; root.model-menu-open = false; root.api-key-visible = false; root.manual-model = false; } }
    Rectangle { x: 0px; y: 120px; width: parent.width - 1px; height: 1px; background: AppColors.border; }

    Text { x: 0px; y: 140px; text: root.active-tab == 0 ? "语音识别服务" : "文本润色服务"; color: AppColors.text; font-size: 14px; font-weight: 650; }
    ServiceCard {
        x: 0px; y: 166px; width: parent.width - 1px;
        icon: root.active-tab == 0 ? @image-url("../../icons/lucide/audio-lines.svg") : @image-url("../../icons/lucide/sparkles.svg");
        name: root.service-name;
        detail: root.active-tab == 0 && !root.asr-configured ? "尚未配置 API Key" : root.configured-model-name.is-empty ? "" : root.configured-model-name + (root.asr-pending-test ? " · 尚未启用" : " · 当前默认");
        status: root.service-status;
        healthy: root.service-healthy;
        open: root.service-menu-open;
        activated => { root.service-menu-open = !root.service-menu-open; root.model-menu-open = false; }
    }

    Text { x: 0px; y: 258px; text: "连接配置"; color: AppColors.text; font-size: 14px; font-weight: 650; }
    Rectangle {
        x: 0px; y: 283px; width: parent.width - 1px; height: root.config-height; border-radius: 12px; background: AppColors.surface;

        Text { x: 18px; y: 17px; text: "API Key"; color: AppColors.text; font-size: 11px; font-weight: 600; }
        Text { x: parent.width - 88px; y: 17px; text: "获取密钥 ↗"; color: AppColors.brand; font-size: 10px; font-weight: 600; }

        asr-field := ApiKeyField {
            visible: root.active-tab == 0;
            x: 18px; y: 39px; width: parent.width - 36px; height: 42px;
            value <=> root.asr-api-key; reveal: root.api-key-visible; error: root.asr-config-error; accessible-name: "火山引擎 API Key";
            accepted(value) => { root.save-asr-config(value, root.asr-model); }
            toggle-reveal => { root.api-key-visible = !root.api-key-visible; }
        }
        if root.active-tab == 1 && root.llm-provider == LlmProvider.sensenova: ApiKeyField {
            x: 18px; y: 39px; width: parent.width - 36px; value <=> root.sensenova-api-key; reveal: root.api-key-visible; error: false; accessible-name: "商汤 SenseNova API Key";
            accepted(value) => { root.save-llm-config(LlmProvider.sensenova, value, root.sensenova-model); }
            toggle-reveal => { root.api-key-visible = !root.api-key-visible; }
        }
        if root.active-tab == 1 && root.llm-provider == LlmProvider.deepseek: ApiKeyField {
            x: 18px; y: 39px; width: parent.width - 36px; value <=> root.deepseek-api-key; reveal: root.api-key-visible; error: false; accessible-name: "DeepSeek API Key";
            accepted(value) => { root.save-llm-config(LlmProvider.deepseek, value, root.deepseek-model); }
            toggle-reveal => { root.api-key-visible = !root.api-key-visible; }
        }

        Text { x: 18px; y: 95px; text: "模型"; color: AppColors.text; font-size: 11px; font-weight: 600; }
        Text { x: 56px; y: 96px; width: parent.width - 164px; text: root.model-discovery-status; color: AppColors.text-muted; font-size: 9px; overflow: elide; }
        Rectangle {
            x: parent.width - 103px; y: 88px; width: 85px; height: 25px; border-radius: 6px; background: fetch-area.has-hover ? AppColors.surface-subtle : transparent;
            opacity: root.active-api-key.is-empty || root.model-discovery-loading ? 0.55 : 1;
            accessible-role: button; accessible-label: root.model-discovery-loading ? "正在获取模型" : "获取模型"; accessible-enabled: !root.active-api-key.is-empty && !root.model-discovery-loading;
            Text { text: root.model-discovery-loading ? "获取中…" : "获取模型"; color: AppColors.brand; font-size: 10px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
            fetch-area := TouchArea { enabled: !root.active-api-key.is-empty && !root.model-discovery-loading; mouse-cursor: self.enabled ? pointer : default; clicked => { root.model-menu-open = false; root.refresh-models(); } }
        }
        Rectangle {
            x: 18px; y: 116px; width: parent.width - 36px; height: 42px; border-radius: 8px; background: AppColors.sidebar;
            if root.active-tab == 0 && root.manual-model: TextInput { x: 15px; width: parent.width - 50px; text <=> root.asr-model; color: AppColors.text; font-size: 12px; vertical-alignment: center; }
            if root.active-tab == 1 && root.llm-provider == LlmProvider.sensenova && root.manual-model: TextInput { x: 15px; width: parent.width - 50px; text <=> root.sensenova-model; color: AppColors.text; font-size: 12px; vertical-alignment: center; }
            if root.active-tab == 1 && root.llm-provider == LlmProvider.deepseek && root.manual-model: TextInput { x: 15px; width: parent.width - 50px; text <=> root.deepseek-model; color: AppColors.text; font-size: 12px; vertical-alignment: center; }
            if !root.manual-model: Text { x: 15px; width: parent.width - 50px; text: root.active-tab == 0 ? root.asr-model-label : root.model-name; color: AppColors.text; font-size: 12px; vertical-alignment: center; overflow: elide; }
            if !root.manual-model: TouchArea { mouse-cursor: pointer; clicked => { root.model-menu-open = !root.model-menu-open; root.service-menu-open = false; } }
            ChevronButton { x: parent.width - 38px; y: (parent.height - 32px) / 2; open: root.model-menu-open; activated => { root.model-menu-open = !root.model-menu-open; root.service-menu-open = false; } }
        }

        Rectangle {
            x: 18px; y: 166px; width: parent.width - 36px; height: 34px; background: transparent;
            accessible-role: button; accessible-label: "高级设置";
            Text { x: 15px; text: "高级设置"; color: AppColors.text; font-size: 11px; font-weight: 600; vertical-alignment: center; }
            if !root.advanced-visible: Text { x: 81px; text: root.active-tab == 0 ? "服务地址" : "服务地址、自定义请求头与数据发送说明"; color: AppColors.text-muted; font-size: 10px; vertical-alignment: center; }
            Image { x: parent.width - 24px; y: 10px; width: 14px; height: 14px; source: root.advanced-visible ? @image-url("../../icons/lucide/chevron-up.svg") : @image-url("../../icons/lucide/chevron-right.svg"); colorize: AppColors.text-muted; }
            TouchArea { mouse-cursor: pointer; clicked => { root.advanced-visible = !root.advanced-visible; root.model-menu-open = false; } }
        }

        if root.advanced-visible: Text { x: 18px; y: 209px; text: "服务地址"; color: AppColors.text; font-size: 11px; font-weight: 600; }
        if root.advanced-visible && root.active-tab == 1: Text { x: parent.width - 119px; y: 209px; text: "+ 自定义请求头"; color: AppColors.brand; font-size: 10px; font-weight: 600; }
        if root.advanced-visible: Rectangle {
            x: 18px; y: 228px; width: parent.width - 36px; height: 36px; border-radius: 8px; background: AppColors.sidebar;
            Text { x: 15px; text: root.active-tab == 0 ? "https://openspeech.bytedance.com" : root.llm-provider == LlmProvider.deepseek ? "https://api.deepseek.com" : "https://token.sensenova.cn/v1"; color: AppColors.text; font-size: 11px; vertical-alignment: center; }
        }
    }

    ModelActionButton {
        x: 0px; y: root.action-y; label: "保存配置"; primary: true; enabled: !root.active-api-key.is-empty;
        activated => {
            if root.active-tab == 0 { root.save-asr-config(root.asr-api-key, root.asr-model); }
            else { root.save-llm-config(root.llm-provider, root.active-api-key, root.model-name); }
        }
    }
    ModelActionButton {
        x: 120px; y: root.action-y; label: root.asr-testing ? "正在测试…" : root.asr-config-error && root.active-tab == 0 ? "重新测试" : "测试连接"; primary: root.asr-config-error && root.active-tab == 0; enabled: !root.active-api-key.is-empty && !root.asr-testing;
        activated => { if root.active-tab == 0 { root.request-asr-test(); } else { root.request-llm-enable(); } }
    }
    Text { x: parent.width - 230px; y: root.action-y + 13px; width: 229px; text: root.api-key-visible ? "5 秒后自动隐藏" : root.asr-testing ? "正在测试连接" : root.asr-config-error && root.active-tab == 0 ? "API Key 无效，请检查后重试" : root.asr-pending-test && root.active-tab == 0 ? "已保存，等待连接测试" : root.service-status; color: root.asr-config-error && root.active-tab == 0 ? AppColors.danger : root.service-healthy ? AppColors.success : AppColors.text-muted; font-size: 10px; font-weight: 650; horizontal-alignment: right; }

    if root.service-menu-open: Rectangle {
        x: 0px; y: 242px; width: parent.width - 1px; height: root.active-tab == 0 ? 72px : 124px; border-radius: 12px; background: AppColors.surface; drop-shadow-blur: 18px; drop-shadow-offset-y: 6px; drop-shadow-color: #1f1f1c1a;
        Rectangle {
            x: 12px; y: 12px; width: parent.width - 24px; height: 48px; border-radius: 8px; background: root.first-service-selected ? AppColors.sidebar : AppColors.surface;
            Image { x: 16px; y: 14px; width: 18px; height: 18px; source: root.active-tab == 0 ? @image-url("../../icons/lucide/audio-lines.svg") : @image-url("../../icons/lucide/sparkles.svg"); colorize: root.first-service-selected ? AppColors.ink : AppColors.text-muted; }
            Text { x: 46px; y: root.first-service-model.is-empty ? 16px : 5px; text: root.active-tab == 0 ? "火山引擎" : "商汤 SenseNova"; color: AppColors.ink; font-size: 12px; font-weight: 650; }
            if !root.first-service-model.is-empty: Text { x: 46px; y: 27px; text: root.first-service-model; color: AppColors.text-muted; font-size: 9px; }
            if root.first-service-selected: Image { x: parent.width - 29px; y: 17px; width: 14px; height: 14px; source: @image-url("../../icons/lucide/check.svg"); colorize: AppColors.success; }
            TouchArea { mouse-cursor: pointer; clicked => { if root.active-tab == 1 { root.llm-provider = LlmProvider.sensenova; root.select-llm-provider(root.llm-provider); root.api-key-visible = false; root.manual-model = false; } root.service-menu-open = false; } }
        }
        if root.active-tab == 1: Rectangle {
            x: 12px; y: 64px; width: parent.width - 24px; height: 48px; border-radius: 8px; background: root.second-service-selected ? AppColors.sidebar : AppColors.surface;
            Image { x: 16px; y: 14px; width: 18px; height: 18px; source: @image-url("../../icons/lucide/sparkles.svg"); colorize: root.second-service-selected ? AppColors.ink : AppColors.text-muted; }
            Text { x: 46px; y: root.second-service-model.is-empty ? 16px : 5px; text: "DeepSeek"; color: AppColors.ink; font-size: 12px; font-weight: 650; }
            if !root.second-service-model.is-empty: Text { x: 46px; y: 27px; text: root.second-service-model; color: AppColors.text-muted; font-size: 9px; }
            if root.second-service-selected: Image { x: parent.width - 29px; y: 17px; width: 14px; height: 14px; source: @image-url("../../icons/lucide/check.svg"); colorize: AppColors.success; }
            TouchArea { mouse-cursor: pointer; clicked => { root.llm-provider = LlmProvider.deepseek; root.select-llm-provider(root.llm-provider); root.api-key-visible = false; root.manual-model = false; root.service-menu-open = false; } }
        }
    }

    if root.model-menu-open: Rectangle {
        x: 18px; y: 443px; width: parent.width - 37px; height: 100px; border-radius: 10px; background: AppColors.surface; drop-shadow-blur: 18px; drop-shadow-offset-y: 6px; drop-shadow-color: #1f1f1c1a;
        ScrollView {
            x: 10px; y: 10px; width: parent.width - 20px; height: parent.height - 20px;
            VerticalLayout {
                spacing: 8px;
                if root.model-discovery-error: Rectangle {
                    height: 36px; border-radius: 7px; background: AppColors.danger-soft;
                    Text { x: 14px; width: parent.width - 48px; text: "模型列表加载失败，请检查网络"; color: AppColors.danger; font-size: 11px; vertical-alignment: center; }
                    Text { x: parent.width - 27px; text: "↻"; color: AppColors.danger; font-size: 14px; vertical-alignment: center; }
                    TouchArea { mouse-cursor: pointer; clicked => { root.refresh-models(); } }
                }
                if root.available-models.length == 0 && !root.model-discovery-error: Rectangle {
                    height: 36px; border-radius: 7px; background: AppColors.surface;
                    Text { x: 14px; text: root.model-discovery-status.is-empty ? "尚未获取模型" : root.model-discovery-status; color: AppColors.text-muted; font-size: 11px; vertical-alignment: center; }
                }
                for model-id in root.available-models: Rectangle {
                    height: 36px; border-radius: 7px; background: !root.manual-model && model-id == root.model-name ? AppColors.sidebar : AppColors.surface;
                    Text { x: 14px; width: parent.width - 48px; text: root.active-tab == 0 ? root.asr-model-label : model-id; color: AppColors.text; font-size: 11px; vertical-alignment: center; overflow: elide; }
                    if !root.manual-model && model-id == root.model-name: Image { x: parent.width - 24px; y: 11px; width: 14px; height: 14px; source: @image-url("../../icons/lucide/check.svg"); colorize: AppColors.success; }
                    TouchArea { mouse-cursor: pointer; clicked => { root.manual-model = false; if root.active-tab == 0 { root.asr-model = model-id; } else if root.llm-provider == LlmProvider.deepseek { root.deepseek-model = model-id; } else { root.sensenova-model = model-id; } root.model-menu-open = false; } }
                }
                Rectangle {
                    height: 36px; border-radius: 7px; background: root.manual-model-selected ? AppColors.sidebar : AppColors.surface;
                    Text { x: 14px; text: "手动输入模型名称"; color: AppColors.text; font-size: 11px; vertical-alignment: center; }
                    if root.manual-model-selected: Image { x: parent.width - 24px; y: 11px; width: 14px; height: 14px; source: @image-url("../../icons/lucide/check.svg"); colorize: AppColors.success; }
                    TouchArea { mouse-cursor: pointer; clicked => { root.manual-model = true; if root.active-tab == 0 { root.asr-model = ""; } else if root.llm-provider == LlmProvider.deepseek { root.deepseek-model = ""; } else { root.sensenova-model = ""; } root.model-menu-open = false; } }
                }
            }
        }
    }
}
