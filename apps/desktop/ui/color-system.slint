// Anthropic-inspired semantic palette with a Saymore green success extension.
export global AppColors {
    out property <color> canvas: #fdfdf7;
    out property <color> surface: #ffffff;
    out property <color> surface-warm: #faf9f5;
    out property <color> surface-subtle: #f4f4f1;
    out property <color> surface-muted: #efeeeb;
    out property <color> border: #e6e5e0;

    out property <color> ink: #141413;
    out property <color> text: #373734;
    out property <color> text-muted: #7b7974;

    out property <color> brand: #d97757;
    out property <color> brand-strong: #c6613f;
    out property <color> brand-soft: #f6e6df;

    out property <color> info: #256bc1;
    out property <color> info-soft: #cbe1fb;
    out property <color> warning: #a86b00;
    out property <color> warning-soft: #f9dda4;
    out property <color> danger: #cf3a3a;
    out property <color> danger-soft: #fad6d6;

    out property <color> success: #176b4c;
    out property <color> success-soft: #e9f3ed;
}
