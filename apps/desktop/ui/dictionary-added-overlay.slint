import { OverlayColors } from "overlay-color-system.slint";

export component DictionaryAddedOverlay inherits Window {
    title: "Saymore Dictionary";
    default-font-family: "PingFang SC";
    preferred-width: 400px;
    preferred-height: 132px;
    min-width: 400px;
    min-height: 132px;
    max-width: 400px;
    max-height: 132px;
    no-frame: true;
    always-on-top: true;
    background: transparent;

    in property <string> entry-id: "";
    in property <string> entry: "";
    in-out property <int> notification-generation: 0;
    callback close-notification();
    callback undo-addition();
    callback view-dictionary();

    Rectangle {
        x: 7px;
        y: 6px;
        width: 386px;
        height: 120px;
        border-radius: 16px;
        background: OverlayColors.surface;
        border-width: 1px;
        border-color: OverlayColors.border-strong;
        drop-shadow-blur: 16px;
        drop-shadow-offset-y: 4px;
        drop-shadow-color: OverlayColors.shadow;

        Rectangle {
            x: 14px;
            y: 16px;
            width: 30px;
            height: 30px;
            border-radius: 15px;
            background: OverlayColors.accent-soft;

            Image {
                x: 7px;
                y: 7px;
                width: 16px;
                height: 16px;
                source: @image-url("../icons/lucide/sparkles.svg");
                colorize: OverlayColors.accent;
            }
        }

        Text {
            x: 54px;
            y: 13px;
            width: 270px;
            height: 22px;
            text: @tr("dictionary.notification.added.title" => "Added to personal dictionary");
            color: OverlayColors.ink-soft;
            font-size: 15px;
            font-weight: 700;
            vertical-alignment: center;
        }
        Text {
            x: 54px;
            y: 38px;
            width: 280px;
            height: 18px;
            text: root.entry;
            color: OverlayColors.text-soft;
            font-size: 13px;
            font-weight: 600;
            overflow: elide;
            vertical-alignment: center;
        }
        Text {
            x: 54px;
            y: 58px;
            width: 310px;
            height: 16px;
            text: @tr("dictionary.notification.added.detail" => "Automatically added based on your repeated corrections");
            color: OverlayColors.text-muted-warm;
            font-size: 11px;
            vertical-alignment: center;
        }

        Rectangle {
            x: 348px;
            y: 12px;
            width: 28px;
            height: 28px;
            border-radius: 8px;
            background: close-area.has-hover ? OverlayColors.surface-hover : transparent;
            accessible-role: button;
            accessible-label: @tr("common.close" => "Close");
            accessible-action-default => { root.close-notification(); }

            Image {
                x: 5px;
                y: 5px;
                width: 18px;
                height: 18px;
                source: @image-url("../icons/lucide/x.svg");
                colorize: OverlayColors.text-muted-warm;
            }
            close-area := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.close-notification(); }
            }
        }

        Rectangle {
            x: 226px;
            y: 80px;
            width: 68px;
            height: 30px;
            border-radius: 8px;
            background: undo-area.has-hover ? OverlayColors.surface-control-hover : OverlayColors.surface-control;
            accessible-role: button;
            accessible-label: @tr("dictionary.notification.undo" => "Undo");
            accessible-action-default => { root.undo-addition(); }

            Text {
                text: @tr("dictionary.notification.undo" => "Undo");
                color: OverlayColors.text-soft;
                font-size: 11px;
                font-weight: 600;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            undo-area := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.undo-addition(); }
            }
        }

        Rectangle {
            x: 302px;
            y: 80px;
            width: 70px;
            height: 30px;
            border-radius: 8px;
            background: view-area.has-hover ? OverlayColors.accent-strong : OverlayColors.accent;
            accessible-role: button;
            accessible-label: @tr("dictionary.notification.view" => "View dictionary");
            accessible-action-default => { root.view-dictionary(); }

            Text {
                text: @tr("dictionary.notification.view" => "View dictionary");
                color: OverlayColors.on-accent;
                font-size: 11px;
                font-weight: 600;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            view-area := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.view-dictionary(); }
            }
        }
    }
}
