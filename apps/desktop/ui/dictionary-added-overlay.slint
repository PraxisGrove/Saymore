export component DictionaryAddedOverlay inherits Window {
    title: "Saymore Dictionary";
    default-font-family: "PingFang SC";
    preferred-width: 400px;
    preferred-height: 132px;
    min-width: 400px;
    min-height: 132px;
    max-width: 400px;
    max-height: 132px;
    no-frame: true;
    always-on-top: true;
    background: transparent;

    in property <string> entry-id: "";
    in property <string> entry: "";
    in-out property <int> notification-generation: 0;
    callback close-notification();
    callback undo-addition();
    callback view-dictionary();

    Rectangle {
        x: 7px;
        y: 6px;
        width: 386px;
        height: 120px;
        border-radius: 16px;
        background: #ffffff;
        border-width: 1px;
        border-color: #dddad2;
        drop-shadow-blur: 16px;
        drop-shadow-offset-y: 4px;
        drop-shadow-color: #1f1f1c24;

        Rectangle {
            x: 14px;
            y: 16px;
            width: 30px;
            height: 30px;
            border-radius: 15px;
            background: #f2ded6;

            Image {
                x: 7px;
                y: 7px;
                width: 16px;
                height: 16px;
                source: @image-url("../icons/lucide/sparkles.svg");
                colorize: #d97757;
            }
        }

        Text {
            x: 54px;
            y: 13px;
            width: 270px;
            height: 22px;
            text: @tr("dictionary.notification.added.title" => "Added to personal dictionary");
            color: #1f1f1c;
            font-size: 15px;
            font-weight: 700;
            vertical-alignment: center;
        }
        Text {
            x: 54px;
            y: 38px;
            width: 280px;
            height: 18px;
            text: root.entry;
            color: #4d4b45;
            font-size: 13px;
            font-weight: 600;
            overflow: elide;
            vertical-alignment: center;
        }
        Text {
            x: 54px;
            y: 58px;
            width: 310px;
            height: 16px;
            text: @tr("dictionary.notification.added.detail" => "Automatically added based on your repeated corrections");
            color: #77746c;
            font-size: 11px;
            vertical-alignment: center;
        }

        Rectangle {
            x: 348px;
            y: 12px;
            width: 28px;
            height: 28px;
            border-radius: 8px;
            background: close-area.has-hover ? #f3f1ed : transparent;
            accessible-role: button;
            accessible-label: @tr("common.close" => "Close");
            accessible-action-default => { root.close-notification(); }

            Image {
                x: 5px;
                y: 5px;
                width: 18px;
                height: 18px;
                source: @image-url("../icons/lucide/x.svg");
                colorize: #77746c;
            }
            close-area := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.close-notification(); }
            }
        }

        Rectangle {
            x: 226px;
            y: 80px;
            width: 68px;
            height: 30px;
            border-radius: 8px;
            background: undo-area.has-hover ? #e5e3dd : #efeee9;
            accessible-role: button;
            accessible-label: @tr("dictionary.notification.undo" => "Undo");
            accessible-action-default => { root.undo-addition(); }

            Text {
                text: @tr("dictionary.notification.undo" => "Undo");
                color: #4d4b45;
                font-size: 11px;
                font-weight: 600;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            undo-area := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.undo-addition(); }
            }
        }

        Rectangle {
            x: 302px;
            y: 80px;
            width: 70px;
            height: 30px;
            border-radius: 8px;
            background: view-area.has-hover ? #c6613f : #d97757;
            accessible-role: button;
            accessible-label: @tr("dictionary.notification.view" => "View dictionary");
            accessible-action-default => { root.view-dictionary(); }

            Text {
                text: @tr("dictionary.notification.view" => "View dictionary");
                color: #ffffff;
                font-size: 11px;
                font-weight: 600;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            view-area := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.view-dictionary(); }
            }
        }
    }
}
