import { AppSidebar } from "sidebar.slint";
import { HomePage } from "pages/home.slint";
import { ModelConsentDialog, ModelsPage } from "pages/models.slint";
import { HistoryListItem, HistoryPage } from "pages/history.slint";
import { DictionaryListItem, DictionaryPage } from "pages/dictionary.slint";
import { SettingsPage } from "pages/settings.slint";
import { AppPage, LlmProvider, SettingsSection } from "components.slint";
import { AppColors } from "color-system.slint";
export { RecordingOverlay } from "recording-overlay.slint";
export { ResultOverlay } from "result-overlay.slint";
export { MicrophoneIntroOverlay, MicrophonePermissionOverlay } from "microphone-access.slint";
export { LlmProvider } from "components.slint";

export component AppWindow inherits Window {
    title: root.development-environment ? "Saymore Preview" : "Saymore";
    default-font-family: "PingFang SC";
    default-font-size: 13px;
    preferred-width: 920px;
    preferred-height: 620px;
    min-width: 820px;
    min-height: 560px;
    background: AppColors.canvas;

    in-out property <AppPage> current-page: AppPage.home;
    in property <bool> development-environment: false;
    in-out property <SettingsSection> settings-section: SettingsSection.general;
    in-out property <bool> focus-asr-config: false;
    in property <bool> authorized: false;
    in property <string> authorization-status: "检测中";
    in property <bool> microphone-authorized: false;
    in property <string> microphone-status: "检测中";
    in property <bool> recording-active: false;
    in property <bool> recording-failed: false;
    in property <bool> recording-complete: false;
    in property <bool> recording-attempted: false;
    in property <float> recording-level: 0;
    in property <string> recording-status: "等待录音";
    in property <string> recording-detail: "单击右 Command 开始";
    in property <string> shortcut-label: "右 Command";
    in property <bool> shortcut-enabled: true;
    in property <bool> delivery-healthy: true;
    in property <string> delivery-status: "文本投递正常";
    in property <string> usage-total-minutes: "0";
    in property <string> usage-total-characters: "0";
    in property <string> usage-average-speed: "0";
    in property <[float]> usage-trend;
    in property <[string]> usage-day-labels;
    in property <int> usage-highlighted-day: -1;
    in property <bool> usage-loading: false;
    in property <bool> usage-error: false;
    in-out property <string> asr-api-key: "";
    in-out property <string> asr-model: "bigmodel_async";
    in property <bool> asr-configured: false;
    in property <bool> asr-config-error: false;
    in property <string> asr-config-status: "未配置";
    in-out property <bool> asr-testing: false;
    in-out property <bool> asr-pending-test: false;
    in-out property <bool> llm-enabled: false;
    in-out property <LlmProvider> llm-provider: LlmProvider.sensenova;
    in-out property <string> sensenova-api-key: "";
    in-out property <string> deepseek-api-key: "";
    in property <bool> sensenova-configured: false;
    in property <bool> deepseek-configured: false;
    in-out property <string> sensenova-model: "";
    in-out property <string> deepseek-model: "";
    in property <string> llm-provider-target: "";
    in property <bool> llm-provider-local: false;
    in property <string> llm-config-status: "未启用";
    in-out property <bool> llm-confirmation-visible: false;
    in-out property <int> model-tab: 0;
    in-out property <[string]> available-models;
    in-out property <bool> model-discovery-loading: false;
    in-out property <bool> model-discovery-error: false;
    in-out property <string> model-discovery-status: "";
    in property <[HistoryListItem]> history-items;
    in property <string> history-status: "";
    in property <bool> history-undo-visible: false;
    in property <bool> history-has-more: false;
    in property <bool> history-locked: false;
    in property <[DictionaryListItem]> dictionary-items;
    in property <string> dictionary-status: "";
    in-out property <bool> history-enabled: true;
    in-out property <string> history-retention: "7 天";
    callback request-authorization();
    callback request-microphone-authorization();
    callback open-microphone-settings();
    callback open-accessibility-settings();
    callback refresh-usage();
    callback save-asr-config(string, string);
    callback delete-asr-config();
    callback request-llm-enable();
    callback set-llm-enabled(bool, string);
    callback save-llm-config(LlmProvider, string, string);
    callback select-llm-provider(LlmProvider);
    callback refresh-models();
    callback request-asr-test();
    callback refresh-history();
    callback load-more-history();
    callback copy-history(string);
    callback delete-history(string);
    callback clear-history();
    callback reset-history();
    callback undo-history-delete();
    callback add-dictionary-word(string, string);
    callback refresh-dictionary();
    callback delete-dictionary-word(string);
    callback import-dictionary-csv();
    callback set-history-enabled(bool);
    callback set-history-retention(string);

    changed current-page => {
        if root.current-page == AppPage.history {
            root.refresh-history();
        }
    }
    changed model-tab => { root.available-models = []; root.model-discovery-status = ""; root.model-discovery-error = false; }
    changed llm-provider => { root.available-models = []; root.model-discovery-status = ""; root.model-discovery-error = false; }

    if root.current-page != AppPage.settings: HorizontalLayout {
        padding: 10px;
        spacing: 20px;

        AppSidebar {
            current-page <=> root.current-page;
        }

        Rectangle {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            background: transparent;

            if root.current-page == AppPage.home: HomePage {
                width: parent.width;
                height: parent.height;
                authorized: root.authorized;
                authorization-status: root.authorization-status;
                microphone-authorized: root.microphone-authorized;
                microphone-status: root.microphone-status;
                asr-configured: root.asr-configured;
                asr-config-error: root.asr-config-error;
                asr-pending-test: root.asr-pending-test;
                asr-config-status: root.asr-config-status;
                shortcut-label: root.shortcut-label;
                shortcut-enabled: root.shortcut-enabled;
                delivery-healthy: root.delivery-healthy;
                delivery-status: root.delivery-status;
                usage-total-minutes: root.usage-total-minutes;
                usage-total-characters: root.usage-total-characters;
                usage-average-speed: root.usage-average-speed;
                usage-trend: root.usage-trend;
                usage-day-labels: root.usage-day-labels;
                usage-highlighted-day: root.usage-highlighted-day;
                usage-loading: root.usage-loading;
                usage-error: root.usage-error;
                refresh-usage => { root.refresh-usage(); }
                open-model-settings => { root.focus-asr-config = true; root.current-page = AppPage.models; }
                open-microphone-settings => { root.open-microphone-settings(); }
                open-accessibility-settings => { root.open-accessibility-settings(); }
                open-delivery-settings => { root.settings-section = SettingsSection.delivery-permissions; root.current-page = AppPage.settings; }
            }

            if root.current-page == AppPage.models: ModelsPage {
                width: parent.width;
                height: parent.height;
                focus-asr-config: root.focus-asr-config;
                asr-api-key <=> root.asr-api-key;
                asr-model <=> root.asr-model;
                asr-configured: root.asr-configured;
                asr-config-error: root.asr-config-error;
                asr-config-status: root.asr-config-status;
                asr-testing <=> root.asr-testing;
                asr-pending-test <=> root.asr-pending-test;
                llm-enabled <=> root.llm-enabled;
                llm-provider <=> root.llm-provider;
                sensenova-api-key <=> root.sensenova-api-key;
                deepseek-api-key <=> root.deepseek-api-key;
                sensenova-configured: root.sensenova-configured;
                deepseek-configured: root.deepseek-configured;
                sensenova-model <=> root.sensenova-model;
                deepseek-model <=> root.deepseek-model;
                llm-provider-target: root.llm-provider-target;
                llm-provider-local: root.llm-provider-local;
                llm-config-status: root.llm-config-status;
                llm-confirmation-visible <=> root.llm-confirmation-visible;
                active-tab <=> root.model-tab;
                available-models <=> root.available-models;
                model-discovery-loading <=> root.model-discovery-loading;
                model-discovery-error <=> root.model-discovery-error;
                model-discovery-status <=> root.model-discovery-status;
                save-asr-config(api-key, model) => { root.save-asr-config(api-key, model); }
                delete-asr-config => { root.delete-asr-config(); }
                request-llm-enable => { root.request-llm-enable(); }
                set-llm-enabled(enabled, base-url) => { root.set-llm-enabled(enabled, base-url); }
                save-llm-config(provider, api-key, model) => { root.save-llm-config(provider, api-key, model); }
                select-llm-provider(provider) => { root.select-llm-provider(provider); }
                refresh-models => { root.refresh-models(); }
                request-asr-test => { root.request-asr-test(); }
            }

            if root.current-page == AppPage.history: HistoryPage {
                width: parent.width;
                height: parent.height;
                items: root.history-items;
                status-text: root.history-status;
                undo-visible: root.history-undo-visible;
                has-more: root.history-has-more;
                locked: root.history-locked;
                refresh => { root.refresh-history(); }
                load-more => { root.load-more-history(); }
                copy(id) => { root.copy-history(id); }
                delete-record(id) => { root.delete-history(id); }
                clear-all => { root.clear-history(); }
                reset => { root.reset-history(); }
                undo-delete => { root.undo-history-delete(); }
            }
            if root.current-page == AppPage.dictionary: DictionaryPage {
                width: parent.width;
                height: parent.height;
                items: root.dictionary-items;
                status-text: root.dictionary-status;
                add-word(word, language) => { root.add-dictionary-word(word, language); }
                delete-word(id) => { root.delete-dictionary-word(id); }
                import-csv => { root.import-dictionary-csv(); }
            }

        }
    }

    if root.current-page == AppPage.settings: SettingsPage {
        width: parent.width;
        height: parent.height;
        current-section <=> root.settings-section;
        authorized: root.authorized;
        authorization-status: root.authorization-status;
        microphone-authorized: root.microphone-authorized;
        microphone-status: root.microphone-status;
        history-enabled <=> root.history-enabled;
        history-retention <=> root.history-retention;
        back-to-app => { root.current-page = AppPage.home; }
        request-authorization => { root.request-authorization(); }
        request-microphone-authorization => { root.request-microphone-authorization(); }
        set-history-enabled(enabled) => { root.set-history-enabled(enabled); }
        set-history-retention(retention) => { root.set-history-retention(retention); }
    }

    if root.development-environment: Rectangle {
        x: parent.width - self.width - 12px;
        y: 12px;
        width: 31px;
        height: 18px;
        border-radius: 5px;
        background: AppColors.warning-soft;
        Text { text: "DEV"; color: AppColors.warning; font-size: 9px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
    }

    if root.llm-confirmation-visible: ModelConsentDialog {
        width: parent.width;
        height: parent.height;
        target: root.llm-provider-target;
        cancelled => { root.llm-confirmation-visible = false; }
        confirmed => {
            root.llm-confirmation-visible = false;
            root.set-llm-enabled(true, root.llm-provider-target);
        }
    }
}
