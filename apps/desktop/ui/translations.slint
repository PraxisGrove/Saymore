    public pure function recording-samples(duration: string, samples: int) -> string {
        return @tr("recording.detail.samples" => "{} · {} input sample" | "{} · {} input samples" % samples, duration, samples);
    }
    public pure function recording-completion(duration: string, characters: int, outcome: string) -> string {
        return @tr("recording.detail.completion" => "{} · {} character · {}" | "{} · {} characters · {}" % characters, duration, characters, outcome);
    }
    public pure function duration-seconds(value: string) -> string {
        return @tr("common.duration.seconds" => "{} sec", value);
    }
    public pure function history-duration(seconds: int) -> string {
        return @tr("history.duration.seconds" => "{} sec", seconds);
    }
    public pure function dictionary-saved(count: int) -> string {
        return @tr("dictionary.status.saved" => "Saved {} entry" | "Saved {} entries" % count, count);
    }
    public pure function dictionary-imported(added: int, skipped: int) -> string {
        return @tr("dictionary.status.imported" => "Imported {} entries · skipped {}", added, skipped);
    }
    public pure function microphone-system-default-named(name: string) -> string {
        return @tr("settings.microphone.system-default-named" => "Automatic (system default: {})", name);
    }
    public pure function microphone-disconnected(name: string) -> string {
        return @tr("settings.microphone.disconnected" => "{} (disconnected)", name);
    }
    public pure function models-fetched(count: int) -> string {
        return @tr("models.fetch.status.complete" => "Fetched {} model" | "Fetched {} models" % count, count);
    }
    public pure function diagnostics-exported(file-name: string) -> string {
        return @tr("settings.diagnostics.status.exported" => "Exported {}", file-name);
    }
    public pure function dictionary-automatically-added(entry: string) -> string {
        return @tr("dictionary.status.automatically-added" => "Added {} automatically", entry);
    }
    public pure function diagnostics-report-version(version: string) -> string {
        return @tr("diagnostics.report.version" => "Version: v{}", version);
    }
    public pure function diagnostics-report-generated(timestamp: string) -> string {
        return @tr("diagnostics.report.generated" => "Generated: {}", timestamp);
    }
}
