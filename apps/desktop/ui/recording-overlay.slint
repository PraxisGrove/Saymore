import "../fonts/InterVariable.ttf";
import { OverlayColors } from "overlay-color-system.slint";

export component RecordingOverlay inherits Window {
    title: "Saymore Recording";
    default-font-family: "Inter";
    preferred-width: 120px;
    preferred-height: 35px;
    min-width: 120px;
    min-height: 35px;
    max-width: 120px;
    max-height: 35px;
    no-frame: true;
    always-on-top: true;
    background: transparent;

    in property <float> recording-level: 0;
    in property <string> processing-label: @tr("recording.processing.transcribing" => "Transcribing");
    in-out property <int> session-generation: 0;
    in-out property <bool> revealed: false;
    // 0 = recording, 1 = processing, 2 = cancelled, 3 = refinement failed
    in property <int> mode: 0;
    private property <float> displayed-level: root.recording-level;
    private property <float> wave-phase: root.revealed && root.mode == 0 ? mod(animation-tick(), 1100ms) / 1100ms : 0;
    animate displayed-level { duration: 130ms; easing: ease-out; }
    callback cancel();
    callback finish();
    callback undo-cancel();

    capsule := Rectangle {
        width: 120px;
        height: 35px;
        opacity: root.revealed ? 1 : 0;
        border-radius: 17.5px;
        background: OverlayColors.recording-surface;
        border-width: 1px;
        border-color: root.mode == 3 ? OverlayColors.recording-warning : OverlayColors.recording-border;
        animate opacity { duration: 110ms; easing: ease-out; }
        animate border-color { duration: 100ms; easing: ease-out; }

        recording-state := Rectangle {
            opacity: root.mode == 0 ? 1 : 0;
            private property <float> wave-energy: 0.18 + root.displayed-level * 0.82;
            animate opacity { duration: 90ms; easing: ease-out; }

            Rectangle {
                x: 3px;
                y: 3.5px;
                width: 28px;
                height: 28px;
                border-radius: 14px;
                background: cancel-area.pressed ? OverlayColors.recording-control-pressed : cancel-area.has-hover ? OverlayColors.recording-control-hover : OverlayColors.recording-control;
                accessible-role: button;
                accessible-label: @tr("recording.cancel.accessible-label" => "Cancel recording");
                accessible-action-default => { root.cancel(); }

                Image {
                    x: 7px;
                    y: 7px;
                    width: 14px;
                    height: 14px;
                    source: @image-url("../icons/lucide/x.svg");
                    colorize: OverlayColors.recording-icon;
                }
                cancel-area := TouchArea { enabled: root.mode == 0 && root.revealed; mouse-cursor: pointer; clicked => { root.cancel(); } }
            }

            for amplitude[index] in [0.38, 0.56, 0.74, 0.90, 1.0, 0.90, 0.74, 0.56, 0.38]: wave-bar := Rectangle {
                private property <float> pulse: 0.68 + 0.32 * abs(sin((root.wave-phase + index * 0.13) * 360deg));
                x: 36px + index * 5.75px;
                width: 3px;
                height: max(3px, 3px + 17px * amplitude * recording-state.wave-energy * wave-bar.pulse);
                y: (parent.height - self.height) / 2;
                border-radius: 2px;
                background: index == 4 ? OverlayColors.recording-wave-accent : OverlayColors.recording-control-light;
            }

            Rectangle {
                x: 89px;
                y: 3.5px;
                width: 28px;
                height: 28px;
                border-radius: 14px;
                background: finish-area.pressed ? OverlayColors.recording-control-light-pressed : finish-area.has-hover ? OverlayColors.recording-control-light-hover : OverlayColors.recording-control-light;
                accessible-role: button;
                accessible-label: @tr("recording.finish.accessible-label" => "Finish recording");
                accessible-action-default => { root.finish(); }

                Image {
                    x: 9px;
                    y: 9px;
                    width: 10px;
                    height: 10px;
                    source: @image-url("../icons/lucide/check.svg");
                    colorize: OverlayColors.ink;
                }
                finish-area := TouchArea { enabled: root.mode == 0 && root.revealed; mouse-cursor: pointer; clicked => { root.finish(); } }
            }
        }

        processing-state := Rectangle {
            opacity: root.mode == 1 ? 1 : 0;
            animate opacity { duration: 90ms; easing: ease-out; }
            spinner := Rectangle {
                private property <float> turn: root.revealed && root.mode == 1 ? mod(animation-tick(), 900ms) / 900ms : 0;
                private property <angle> angle: spinner.turn * 360deg;
                x: 4px;
                y: 5.5px;
                width: 24px;
                height: 24px;
                border-radius: 12px;
                background: transparent;

                Rectangle { x: 2px; y: 2px; width: 20px; height: 20px; border-radius: 10px; background: OverlayColors.recording-spinner-track; Rectangle { x: 3px; y: 3px; width: 14px; height: 14px; border-radius: 7px; background: OverlayColors.recording-surface; } }
                arc-layer := Rectangle {
                    x: 2px;
                    y: 2px;
                    width: 20px;
                    height: 20px;
                    border-radius: 10px;
                    background: OverlayColors.recording-spinner-arc;
                    transform-origin: { x: 10px, y: 10px };
                    transform-rotation: spinner.angle;

                    Rectangle { x: 3px; y: 3px; width: 14px; height: 14px; border-radius: 7px; background: OverlayColors.recording-surface; }
                    Rectangle { x: 8.5px; y: 0px; width: 3px; height: 3px; border-radius: 1.5px; background: OverlayColors.recording-accent; }
                    Rectangle { x: 16.7px; y: 11.7px; width: 3px; height: 3px; border-radius: 1.5px; background: OverlayColors.recording-accent; }
                }
            }
            Text { x: 32px; width: 88px; text: root.processing-label; color: OverlayColors.recording-text; font-size: 12px; font-weight: 650; horizontal-alignment: center; vertical-alignment: center; }
        }

        cancelled-state := Rectangle {
            opacity: root.mode == 2 ? 1 : 0;
            animate opacity { duration: 90ms; easing: ease-out; }
            Text {
                x: 9px;
                width: 50px;
                text: @tr("recording.cancelled" => "Cancelled");
                color: OverlayColors.recording-muted;
                font-size: 12px;
                font-weight: 650;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            Rectangle { x: 63.5px; y: 10.5px; width: 1px; height: 14px; background: OverlayColors.recording-divider; }
            Rectangle {
                x: 69px; width: 41px; height: parent.height; border-radius: 13px; background: undo-area.pressed ? OverlayColors.recording-pressed : undo-area.has-hover ? OverlayColors.recording-hover : transparent;
                accessible-role: button; accessible-label: @tr("recording.undo-cancel.accessible-label" => "Undo cancellation");
                accessible-action-default => { root.undo-cancel(); }
                Text { text: @tr("common.undo" => "Undo"); color: OverlayColors.recording-text-warm; font-size: 11px; font-weight: 650; horizontal-alignment: center; vertical-alignment: center; }
                undo-area := TouchArea { enabled: root.mode == 2 && root.revealed; mouse-cursor: pointer; clicked => { root.undo-cancel(); } }
            }
        }

        failure-state := Rectangle {
            opacity: root.mode == 3 ? 1 : 0;
            animate opacity { duration: 90ms; easing: ease-out; }
            Rectangle {
                x: 3px; y: 3px; width: 29px; height: 29px; border-radius: 14.5px; background: OverlayColors.recording-warning;
                Text { text: "!"; color: OverlayColors.on-accent; font-size: 16px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
            }
            Text { x: 32px; width: 88px; text: @tr("recording.refinement-failed" => "Polishing failed"); color: OverlayColors.recording-text; font-size: 12px; font-weight: 650; horizontal-alignment: center; vertical-alignment: center; }
        }
    }
}
